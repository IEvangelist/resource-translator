{
  "name": "@ievangelist/resource-translator",
  "version": "3.2.0",
  "preview": false,
  "keywords": [
    "github",
    "actions",
    "resource",
    "localization",
    "azure",
    "translator",
    "i18n",
    "l10n",
    "resx",
    "xliff",
    "po"
  ],
  "description": "A GitHub Action that uses Azure AI Translator to machine-translate resource files (.resx, .restext, .ini, .xliff, .po, .json) and open pull requests with the results.",
  "main": "dist/resource-translator/index.js",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib",
    "!.DS_Store"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs",
    "clean": "node -e \"require('fs').rmSync('lib',{recursive:true,force:true});require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "tsc --noEmit -p tsconfig.test.json && jest --coverage",
    "test:watch": "jest --watch",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "verify": "npm run lint && npm run format:check && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IEvangelist/resource-translator.git"
  },
  "author": "IEvangelist",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/IEvangelist/resource-translator/issues"
  },
  "homepage": "https://github.com/IEvangelist/resource-translator#readme",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/github": "^8.0.1",
    "@actions/glob": "^0.5.1",
    "@aws-sdk/client-translate": "^3.1085.0",
    "@azure-rest/ai-translation-text": "^2.0.0",
    "@google-cloud/translate": "^9.4.2",
    "js-yaml": "^5.2.1",
    "minimatch": "^10.2.5",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^3.15.0"
    },
    "@babel/core": "^7.29.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "@types/xml2js": "^0.4.14",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  }
}
