---
import { Icon } from "astro-icon/components";
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import Logo from "../components/Logo.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { localizedHref } from "../i18n/routes";
import { code, type LocalizedReplacements } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "index");
const link = (path: string) => localizedHref(locale, path);

const workflow = `name: translate
on:
  push:
    branches: [main]
    paths: ["**/*.en.resx", "**/*.en.json"]

permissions:
  contents: write
  pull-requests: write

jobs:
  translate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - id: translator
        uses: IEvangelist/resource-translator@v3
        with:
          sourceLocale: en
          subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
          endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
          region: \${{ secrets.TRANSLATOR_REGION }}
          toLocales: '["fr","de","es","ja"]'

      - if: steps.translator.outputs.has-new-translations == 'true'
        uses: peter-evans/create-pull-request@v7
        with:
          branch: machine-translation
          title: \${{ steps.translator.outputs.summary-title }}
          body:  \${{ steps.translator.outputs.summary-details }}
          labels: localization
`;

type Feature = {
  icon: string;
  title: string;
  body: string;
  values?: LocalizedReplacements;
  accent: string;
};

type FormatBadge = {
  ext: string;
  note: string;
  values?: LocalizedReplacements;
};

const featureValues = {
  formats: {
    resx: code(".resx"),
    xliff: code(".xliff"),
    po: code(".po"),
    json: code(".json"),
    ini: code(".ini"),
    restext: code(".restext"),
  },
  config: {
    configPath: code(".github/resource-translator.yml"),
  },
  glossary: {
    cpp: code("C++"),
    dotnet: code(".NET"),
  },
  outputs: {
    summaryTitle: code("summary-title"),
    summaryDetails: code("summary-details"),
    hasNewTranslations: code("has-new-translations"),
  },
  sdk: {
    azureSdk: code("@azure-rest/ai-translation-text"),
    corePipeline: code("@azure/core-rest-pipeline"),
    statusCodes: code("408/429/5xx"),
    esbuild: code("esbuild"),
  },
} satisfies Record<string, LocalizedReplacements>;

const features: Feature[] = [
  {
    icon: "lucide:languages",
    title: copy.features.formats.title,
    body: copy.features.formats.body,
    values: featureValues.formats,
    accent: "from-(--color-brand-500) to-(--color-accent-500)",
  },
  {
    icon: "lucide:settings-2",
    title: copy.features.config.title,
    body: copy.features.config.body,
    values: featureValues.config,
    accent: "from-(--color-accent-500) to-(--color-warm-500)",
  },
  {
    icon: "lucide:wand-sparkles",
    title: copy.features.glossary.title,
    body: copy.features.glossary.body,
    values: featureValues.glossary,
    accent: "from-(--color-warm-500) to-(--color-brand-500)",
  },
  {
    icon: "lucide:shield-check",
    title: copy.features.dryRun.title,
    body: copy.features.dryRun.body,
    accent: "from-(--color-cool-500) to-(--color-brand-500)",
  },
  {
    icon: "lucide:git-pull-request",
    title: copy.features.outputs.title,
    body: copy.features.outputs.body,
    values: featureValues.outputs,
    accent: "from-(--color-brand-500) to-(--color-cool-500)",
  },
  {
    icon: "lucide:zap",
    title: copy.features.sdk.title,
    body: copy.features.sdk.body,
    values: featureValues.sdk,
    accent: "from-(--color-accent-500) to-(--color-cool-500)",
  },
];

const formats: FormatBadge[] = [
  { ext: ".resx", note: copy.formatNotes.resx, values: { dotnet: code(".NET") } },
  { ext: ".xliff", note: copy.formatNotes.xliff },
  { ext: ".po", note: copy.formatNotes.po },
  { ext: ".json", note: copy.formatNotes.json },
  { ext: ".ini", note: copy.formatNotes.ini, values: { keyValue: code("key=value") } },
  { ext: ".restext", note: copy.formatNotes.restext },
];
---

<DocLayout
  title={copy.title}
  description={copy.description}
  socialTitle={copy.socialTitle}
  hideSidebar
  locale={locale}
  slug="index"
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="hero-mesh pointer-events-none absolute inset-0 -z-10"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,transparent_60%,var(--bg))]"
    >
    </div>

    <div class="mx-auto max-w-6xl px-4 pt-12 pb-16 sm:px-6 sm:pt-24 sm:pb-28">
      <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
        <div>
          <div
            class="mb-6 inline-flex items-center gap-2 rounded-full border border-(--border) bg-(--bg-elevated) px-3 py-1 text-xs font-medium text-(--fg-muted)"
          >
            <Icon
              name="lucide:sparkles"
              class="size-3.5 text-(--color-warm-700) dark:text-(--color-warm-300)"
            />
            <span>{copy.badge}</span>
          </div>

          <h1
            class="text-balance text-5xl font-bold tracking-tight sm:text-6xl"
            transition:name="hero-title"
          >
            {copy.headlinePrefix}
            <span class="text-gradient">{copy.headlineAccent}</span>
          </h1>

          <p
            class="mt-6 max-w-xl text-balance text-lg leading-relaxed text-(--fg-muted)"
          >
            {copy.lede}
          </p>

          <div class="mt-9 flex flex-wrap items-center gap-3">
            <a
              href={link("/getting-started")}
              class="group inline-flex items-center gap-2 rounded-md bg-(--color-brand-700) px-5 py-2.5 text-sm font-semibold text-white no-underline shadow-lg shadow-(--color-brand-500)/20 hover:bg-(--color-brand-600) hover:shadow-xl hover:shadow-(--color-accent-500)/30 transition-all"
            >
              <Icon name="lucide:rocket" class="size-4" />
              {copy.primaryCta}
              <Icon
                name="lucide:arrow-right"
                class="size-4 transition-transform group-hover:translate-x-0.5"
              />
            </a>
            <a
              href="https://github.com/IEvangelist/resource-translator"
              rel="noopener"
              target="_blank"
              class="inline-flex items-center gap-2 rounded-md border border-(--border) bg-(--bg-elevated) px-5 py-2.5 text-sm font-semibold text-(--fg) no-underline hover:border-(--color-brand-500)/50 hover:text-(--color-brand-700) dark:hover:text-(--color-brand-200)"
            >
              <Icon name="simple-icons:github" class="size-4" />
              {copy.secondaryCta}
            </a>
          </div>

          <ul
            class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-(--fg-muted)"
          >
            <li class="inline-flex items-center gap-1.5">
              <Icon
                name="lucide:check"
                class="size-3.5 text-(--color-brand-700) dark:text-(--color-brand-200)"
              />
              {copy.stats.audit}
            </li>
            <li class="inline-flex items-center gap-1.5">
              <Icon
                name="lucide:check"
                class="size-3.5 text-(--color-brand-700) dark:text-(--color-brand-200)"
              />
              {copy.stats.tests}
            </li>
            <li class="inline-flex items-center gap-1.5">
              <Icon
                name="lucide:check"
                class="size-3.5 text-(--color-brand-700) dark:text-(--color-brand-200)"
              />
              {copy.stats.node}
            </li>
            <li class="inline-flex items-center gap-1.5">
              <Icon
                name="lucide:check"
                class="size-3.5 text-(--color-brand-700) dark:text-(--color-brand-200)"
              />
              {copy.stats.sdk}
            </li>
          </ul>
        </div>

        <!-- Floating logo -->
        <div class="relative mx-auto lg:mx-0">
          <div
            aria-hidden="true"
            class="absolute -inset-6 rounded-full bg-linear-to-br from-(--color-brand-500)/30 via-(--color-accent-500)/30 to-(--color-warm-500)/30 blur-2xl"
          >
          </div>
          <Logo
            size={160}
            class="relative rounded-3xl shadow-2xl shadow-(--color-brand-500)/30 sm:size-[200px] lg:size-[220px]"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- FORMAT BADGES -->
  <section class="border-y border-(--border) bg-(--bg-elevated)">
    <div
      class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-3 px-6 py-6 sm:gap-6"
    >
      <span class="text-xs font-semibold uppercase tracking-wider text-(--fg-muted)">
        {copy.supports}
      </span>
      {
        formats.map((f) => (
          <span class="group inline-flex items-center gap-1.5 rounded-full border border-(--border) bg-(--bg) px-3 py-1 text-xs font-mono transition-colors hover:border-(--color-brand-500)/50 hover:text-(--color-brand-700) dark:hover:text-(--color-brand-200)">
            <Icon name="lucide:file-text" class="size-3 opacity-60" />
            <span class="font-semibold">{f.ext}</span>
            <span class="text-(--fg-muted)">
              <LocalizedText text={f.note} values={f.values} />
            </span>
          </span>
        ))
      }
    </div>
  </section>

  <!-- FEATURES -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="text-sm font-semibold uppercase tracking-wider text-(--color-accent-700) dark:text-(--color-accent-300)"
      >
        {copy.builtForShipping}
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        {copy.workflowTitle}
      </h2>
      <p class="mt-4 text-(--fg-muted)">
        {copy.workflowBody}
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="group relative overflow-hidden rounded-2xl border border-(--border) bg-(--bg-elevated) p-6 transition-all hover:-translate-y-1 hover:border-(--color-brand-500)/40 hover:shadow-xl hover:shadow-(--color-brand-500)/10">
            <div
              aria-hidden="true"
              class:list={[
                "absolute -right-12 -top-12 size-32 rounded-full bg-linear-to-br opacity-30 blur-2xl transition-opacity group-hover:opacity-60",
                f.accent,
              ]}
            />
            <div
              class:list={[
                "relative inline-flex size-11 items-center justify-center rounded-xl bg-linear-to-br text-white shadow-md",
                f.accent,
              ]}
            >
              <Icon name={f.icon} class="size-5" />
            </div>
            <h3 class="relative mt-5 text-lg font-semibold">{f.title}</h3>
            <p class="relative mt-2 text-sm leading-relaxed text-(--fg-muted)">
              <LocalizedText text={f.body} values={f.values} />
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- WORKFLOW PREVIEW -->
  <section class="mx-auto max-w-5xl px-6 pb-20">
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="text-sm font-semibold uppercase tracking-wider text-(--color-warm-700) dark:text-(--color-warm-300)"
      >
        {copy.workflowPreview.eyebrow}
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
        {copy.workflowPreview.titlePrefix}
        <span class="text-gradient">{copy.workflowPreview.titleAccent}</span>
      </h2>
      <p class="mt-4 text-(--fg-muted)">
        {copy.workflowPreview.body}
      </p>
    </div>

    <div class="mt-10">
      <Code code={workflow} lang="yaml" title=".github/workflows/translate.yml" />
    </div>

    <div class="mt-8 flex justify-center">
      <a
        href={link("/getting-started")}
        class="group inline-flex items-center gap-2 text-sm font-semibold text-(--color-brand-700) dark:text-(--color-brand-200)"
      >
        {copy.workflowPreview.setupLink}
        <Icon
          name="lucide:arrow-right"
          class="size-4 transition-transform group-hover:translate-x-1"
        />
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    <div
      class="relative overflow-hidden rounded-3xl border border-(--border) bg-(--color-brand-700) p-10 text-white shadow-2xl shadow-(--color-brand-500)/20 sm:p-14"
    >
      <div class="grid gap-8 sm:grid-cols-[1fr_auto] sm:items-center">
        <div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            {copy.cta.title}
          </h2>
          <p class="mt-3 max-w-xl text-white">
            {copy.cta.body}
          </p>
        </div>
        <a
          href={link("/getting-started")}
          class="group inline-flex items-center justify-center gap-2 rounded-md bg-white px-6 py-3 text-sm font-bold text-(--color-brand-700) no-underline shadow-lg hover:bg-white/95"
        >
          <Icon name="lucide:rocket" class="size-4" />
          {copy.cta.button}
          <Icon
            name="lucide:arrow-right"
            class="size-4 transition-transform group-hover:translate-x-0.5"
          />
        </a>
      </div>
    </div>
  </section>
</DocLayout>
