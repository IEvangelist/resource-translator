---
import { Icon } from "astro-icon/components";
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import TranslationOrbit from "../components/TranslationOrbit.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { localizedHref } from "../i18n/routes";
import { code, type LocalizedReplacements } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "index");
const link = (path: string) => localizedHref(locale, path);
const displayText = (value: string) =>
  value
    .replaceAll("\u2014", " - ")
    .replaceAll("\u2013", " - ")
    .replaceAll(" · ", ", ");

const workflow = `name: translate
on:
  push:
    paths: ["**/*.en.resx", "**/*.en.json"]

permissions:
  contents: write
  pull-requests: write

jobs:
  translate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - id: translator
        uses: IEvangelist/resource-translator@v3
        with:
          sourceLocale: en
          provider: |
            azure:
              subscriptionKey: \${{ secrets.KEY }}
              endpoint: \${{ secrets.ENDPOINT }}
              region: \${{ secrets.REGION }}
          toLocales: '["fr","de","es","ja"]'

      - uses: peter-evans/create-pull-request@v7
        with:
          title: Update translations
`;

type Feature = {
  icon: string;
  title: string;
  body: string;
  values?: LocalizedReplacements;
  layout: "lead" | "wide" | "side";
  visual?: "formats" | "providers";
  eyebrow?: string;
  stat?: string;
  featured?: boolean;
};

type FormatBadge = {
  ext: string;
  note: string;
  values?: LocalizedReplacements;
};

const featureValues = {
  formats: {
    resx: code(".resx"),
    xliff: code(".xliff"),
    po: code(".po"),
    json: code(".json"),
    ini: code(".ini"),
    restext: code(".restext"),
  },
  config: {
    configPath: code(".github/resource-translator.yml"),
  },
  glossary: {
    cpp: code("C++"),
    dotnet: code(".NET"),
  },
  outputs: {
    summaryTitle: code("summary-title"),
    summaryDetails: code("summary-details"),
    hasNewTranslations: code("has-new-translations"),
  },
  sdk: {
    azureSdk: code("@azure-rest/ai-translation-text"),
    awsSdk: code("@aws-sdk/client-translate"),
    googleSdk: code("@google-cloud/translate"),
    statusCodes: code("408/429/5xx"),
    esbuild: code("esbuild"),
  },
  smartDetection: {
    changeDetection: code("changeDetection"),
    stateManifest: code(".github/resource-translator-state.json"),
    snapshotOnly: code("snapshotOnly"),
  },
} satisfies Record<string, LocalizedReplacements>;

const features: Feature[] = [
  {
    icon: "lucide:sparkles",
    title: copy.features.smartDetection.title,
    body: copy.features.smartDetection.body,
    values: featureValues.smartDetection,
    layout: "lead",
    eyebrow: copy.features.smartDetection.eyebrow,
    stat: copy.features.smartDetection.stat,
    featured: true,
  },
  {
    icon: "lucide:languages",
    title: copy.features.formats.title,
    body: copy.features.formats.body,
    values: featureValues.formats,
    layout: "side",
    visual: "formats",
  },
  {
    icon: "lucide:settings-2",
    title: copy.features.config.title,
    body: copy.features.config.body,
    values: featureValues.config,
    layout: "side",
  },
  {
    icon: "lucide:wand-sparkles",
    title: copy.features.glossary.title,
    body: copy.features.glossary.body,
    values: featureValues.glossary,
    layout: "wide",
  },
  {
    icon: "lucide:shield-check",
    title: copy.features.dryRun.title,
    body: copy.features.dryRun.body,
    layout: "side",
  },
  {
    icon: "lucide:git-pull-request",
    title: copy.features.outputs.title,
    body: copy.features.outputs.body,
    values: featureValues.outputs,
    layout: "side",
  },
  {
    icon: "lucide:zap",
    title: copy.features.sdk.title,
    body: copy.features.sdk.body,
    values: featureValues.sdk,
    layout: "wide",
    visual: "providers",
  },
];

const formats: FormatBadge[] = [
  {
    ext: ".resx",
    note: copy.formatNotes.resx,
    values: { dotnet: code(".NET") },
  },
  { ext: ".xliff", note: copy.formatNotes.xliff },
  { ext: ".po", note: copy.formatNotes.po },
  { ext: ".json", note: copy.formatNotes.json },
  {
    ext: ".ini",
    note: copy.formatNotes.ini,
    values: { keyValue: code("key=value") },
  },
  { ext: ".restext", note: copy.formatNotes.restext },
];
---

<DocLayout
  title={displayText(copy.title)}
  description={displayText(copy.description)}
  socialTitle={displayText(copy.socialTitle)}
  hideSidebar
  locale={locale}
  slug="index"
>
  <div class="landing-page">
    <section class="landing-hero">
      <div class="hero-wash" aria-hidden="true"></div>
      <div class="hero-shell">
        <div class="hero-copy">
          <h1
            class="text-balance text-5xl font-bold tracking-tight sm:text-6xl"
            transition:name="hero-title"
            data-hero-item
          >
            {displayText(copy.headlinePrefix)}
            {" "}
            <span class="text-gradient">{displayText(copy.headlineAccent)}</span
            >
          </h1>

          <p
            class="max-w-xl text-balance text-lg leading-relaxed text-(--fg-muted)"
            data-hero-item
          >
            {displayText(copy.workflowPreview.body)}
          </p>

          <div class="hero-actions" data-hero-item>
            <a
              href={link("/getting-started")}
              class="landing-button group inline-flex items-center gap-2 whitespace-nowrap rounded-lg bg-(--color-brand-700) px-5 py-3 text-sm font-semibold text-white no-underline shadow-lg shadow-(--color-brand-500)/20 hover:bg-(--color-brand-600)"
            >
              <Icon name="lucide:rocket" class="size-4" />
              {displayText(copy.primaryCta)}
              <Icon
                name="lucide:arrow-right"
                class="size-4 transition-transform group-hover:translate-x-0.5"
              />
            </a>
            <a
              href="https://github.com/IEvangelist/resource-translator"
              rel="noopener"
              target="_blank"
              class="landing-button inline-flex items-center gap-2 whitespace-nowrap rounded-lg border border-(--border) bg-(--bg-elevated) px-5 py-3 text-sm font-semibold text-(--fg) no-underline hover:border-(--color-brand-500)/60 hover:text-(--color-brand-700) dark:hover:text-(--color-brand-200)"
            >
              <Icon name="simple-icons:github" class="size-4" />
              {displayText(copy.secondaryCta)}
            </a>
          </div>
        </div>

        <div class="hero-visual" data-hero-visual>
          <TranslationOrbit copy={copy.heroDemo} />
        </div>
      </div>
    </section>

    <section class="landing-proof" data-landing-reveal>
      <h2 class="sr-only">{displayText(copy.supports)}</h2>
      <div class="proof-shell">
        <div class="proof-cell proof-metric">
          <span class="proof-icon" aria-hidden="true">
            <Icon name="lucide:shield-check" class="size-5" />
          </span>
          <strong>{displayText(copy.stats.audit)}</strong>
        </div>
        <div class="proof-cell proof-metric">
          <span class="proof-icon" aria-hidden="true">
            <Icon name="lucide:check" class="size-5" />
          </span>
          <strong>{displayText(copy.stats.tests)}</strong>
        </div>
        <div class="proof-cell proof-vendors">
          <div class="proof-vendor-copy">
            <strong>{displayText(copy.stats.sdk)}</strong>
            <span>{displayText(copy.stats.node)}</span>
          </div>
          <div class="vendor-list" aria-hidden="true">
            <span class="vendor-mark">
              <Icon
                name="simple-icons:microsoftazure"
                class="vendor-azure size-7"
              />
            </span>
            <span class="vendor-mark">
              <Icon
                name="simple-icons:amazonwebservices"
                class="vendor-aws size-7"
              />
            </span>
            <span class="vendor-mark">
              <Icon
                name="simple-icons:googlecloud"
                class="vendor-google size-7"
              />
            </span>
          </div>
        </div>
      </div>
    </section>

    <section class="landing-features">
      <div class="section-shell">
        <div class="section-heading" data-landing-reveal>
          <p class="section-eyebrow">{displayText(copy.builtForShipping)}</p>
          <h2>{displayText(copy.workflowTitle)}</h2>
          <p>{displayText(copy.workflowBody)}</p>
        </div>

        <div class="feature-bento">
          {
            features.map((feature, index) => (
              <article
                class="feature-card"
                data-layout={feature.layout}
                data-visual={feature.visual}
                data-landing-reveal
                style={`--reveal-delay: ${Math.min(index * 55, 220)}ms`}
              >
                <div class="feature-icon">
                  <Icon name={feature.icon} class="size-5" />
                </div>

                {feature.eyebrow && (
                  <p class="feature-eyebrow">{displayText(feature.eyebrow)}</p>
                )}

                <h3>{displayText(feature.title)}</h3>
                <p class="feature-body">
                  <LocalizedText
                    text={displayText(feature.body)}
                    values={feature.values}
                  />
                </p>

                {feature.featured && (
                  <div class="change-path" aria-hidden="true">
                    <span>
                      <Icon name="lucide:file-code-2" class="size-4" />
                    </span>
                    <i />
                    <span>
                      <Icon name="lucide:sparkles" class="size-4" />
                    </span>
                    <i />
                    <span>
                      <Icon name="lucide:git-pull-request" class="size-4" />
                    </span>
                  </div>
                )}

                {feature.visual === "formats" && (
                  <div class="format-cloud" aria-hidden="true">
                    {formats.map((format) => (
                      <code>{format.ext}</code>
                    ))}
                  </div>
                )}

                {feature.visual === "providers" && (
                  <div class="provider-cloud" aria-hidden="true">
                    <span class="vendor-mark">
                      <Icon
                        name="simple-icons:microsoftazure"
                        class="vendor-azure size-8"
                      />
                    </span>
                    <span class="vendor-mark">
                      <Icon
                        name="simple-icons:amazonwebservices"
                        class="vendor-aws size-8"
                      />
                    </span>
                    <span class="vendor-mark">
                      <Icon
                        name="simple-icons:googlecloud"
                        class="vendor-google size-8"
                      />
                    </span>
                  </div>
                )}

                {feature.stat && (
                  <p class="feature-stat">
                    <Icon name="lucide:check" class="size-3.5" />
                    {displayText(feature.stat)}
                  </p>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="landing-workflow">
      <div class="workflow-shell">
        <div class="workflow-copy" data-landing-reveal>
          <h2>
            {displayText(copy.workflowPreview.titlePrefix)}
            {" "}
            <span class="text-gradient">
              {displayText(copy.workflowPreview.titleAccent)}
            </span>
          </h2>
          <p>{displayText(copy.lede)}</p>
          <a href={link("/getting-started")} class="workflow-link group">
            {displayText(copy.primaryCta)}
            <Icon
              name="lucide:arrow-right"
              class="size-4 transition-transform group-hover:translate-x-1"
            />
          </a>
        </div>

        <div
          class="workflow-code"
          data-landing-reveal
          style="--reveal-delay: 90ms"
        >
          <Code
            code={workflow}
            lang="yaml"
            title=".github/workflows/translate.yml"
          />
        </div>
      </div>
    </section>

    <section class="landing-cta">
      <div class="cta-panel" data-landing-reveal>
        <div>
          <h2>{displayText(copy.cta.title)}</h2>
          <p>{displayText(copy.cta.body)}</p>
        </div>
        <a
          href={link("/getting-started")}
          class="landing-button group inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg bg-white px-6 py-3 text-sm font-bold text-(--color-brand-700) no-underline shadow-lg hover:bg-white/95"
        >
          <Icon name="lucide:rocket" class="size-4" />
          {displayText(copy.primaryCta)}
          <Icon
            name="lucide:arrow-right"
            class="size-4 transition-transform group-hover:translate-x-0.5"
          />
        </a>
      </div>
    </section>
  </div>
</DocLayout>

<style>
  .landing-page {
    overflow: clip;
    background: var(--bg);
  }

  .landing-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-wash {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(
        circle at 82% 46%,
        rgba(110, 103, 248, 0.18),
        transparent 34%
      ),
      linear-gradient(125deg, rgba(110, 103, 248, 0.08), transparent 42%);
    pointer-events: none;
  }

  :global(.dark) .hero-wash {
    background:
      radial-gradient(
        circle at 82% 46%,
        rgba(110, 103, 248, 0.22),
        transparent 34%
      ),
      linear-gradient(125deg, rgba(110, 103, 248, 0.1), transparent 42%);
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(31rem, 1.12fr);
    align-items: center;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    width: min(100% - 2rem, 80rem);
    min-height: calc(100dvh - 4.125rem);
    margin-inline: auto;
    padding-block: clamp(2.5rem, 6vh, 4.5rem);
  }

  .hero-copy {
    display: grid;
    gap: 1.5rem;
    max-width: 39rem;
  }

  .hero-copy h1 {
    margin: 0;
    line-height: 0.98;
  }

  .hero-copy p {
    margin: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-visual {
    min-width: 0;
  }

  .landing-button {
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 220ms ease,
      transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .landing-button:active {
    transform: translateY(1px) scale(0.985);
  }

  .landing-proof {
    border-bottom: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .proof-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 0.78fr) minmax(
        0,
        1.44fr
      );
    width: min(100% - 2rem, 80rem);
    margin: 0 auto;
  }

  .proof-cell {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 7rem;
    padding: 1.25rem 1.5rem;
    color: var(--fg-muted);
  }

  .proof-cell + .proof-cell {
    border-inline-start: 1px solid var(--border);
  }

  .proof-icon {
    display: grid;
    flex: none;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgba(110, 103, 248, 0.25);
    border-radius: 0.8rem;
    color: var(--link);
    background: var(--bg);
  }

  .proof-metric strong {
    color: var(--fg);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    line-height: 1.3;
    letter-spacing: -0.025em;
  }

  .proof-vendors {
    justify-content: space-between;
  }

  .proof-vendor-copy {
    display: grid;
    gap: 0.3rem;
  }

  .proof-vendor-copy strong {
    color: var(--fg);
    font-size: 0.95rem;
  }

  .proof-vendor-copy span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .vendor-list,
  .provider-cloud {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .vendor-mark {
    display: grid;
    flex: none;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    background: var(--bg);
    box-shadow: 0 0.55rem 1.4rem rgba(70, 53, 188, 0.07);
  }

  .vendor-azure {
    color: #0078d4;
  }

  .vendor-aws {
    color: #ff9900;
  }

  .vendor-google {
    color: #4285f4;
  }

  .section-shell,
  .workflow-shell {
    width: min(100% - 2rem, 80rem);
    margin-inline: auto;
  }

  .landing-features {
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .section-heading {
    display: grid;
    gap: 0.9rem;
    max-width: 45rem;
  }

  .section-eyebrow,
  .feature-eyebrow {
    margin: 0;
    color: var(--link);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .section-heading h2,
  .workflow-copy h2,
  .cta-panel h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 650;
    line-height: 1.02;
    letter-spacing: -0.045em;
  }

  .section-heading > p:last-child,
  .workflow-copy > p,
  .cta-panel p {
    max-width: 65ch;
    margin: 0;
    color: var(--fg-muted);
    line-height: 1.75;
  }

  .feature-bento {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 3.25rem;
  }

  .feature-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 16rem;
    overflow: hidden;
    padding: clamp(1.35rem, 3vw, 2rem);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    background: var(--bg-elevated);
    transition:
      border-color 220ms ease,
      box-shadow 280ms ease,
      transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feature-card[data-layout="lead"],
  .feature-card[data-layout="wide"] {
    grid-column: span 7;
  }

  .feature-card[data-layout="side"] {
    grid-column: span 5;
  }

  .feature-card[data-layout="lead"] {
    grid-row: span 2;
    min-height: 33rem;
    background:
      linear-gradient(145deg, rgba(110, 103, 248, 0.16), transparent 55%),
      var(--bg-elevated);
  }

  .feature-card[data-visual="formats"] {
    background:
      linear-gradient(rgba(110, 103, 248, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 103, 248, 0.06) 1px, transparent 1px),
      var(--bg-elevated);
    background-size: 1.5rem 1.5rem;
  }

  .feature-card[data-visual="providers"] {
    background:
      radial-gradient(
        circle at 90% 15%,
        rgba(110, 103, 248, 0.18),
        transparent 36%
      ),
      var(--bg-elevated);
  }

  .feature-icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgba(110, 103, 248, 0.24);
    border-radius: 0.8rem;
    color: var(--color-brand-700);
    background: var(--color-brand-100);
  }

  :global(.dark) .feature-icon {
    color: var(--color-brand-200);
    background: rgba(110, 103, 248, 0.16);
  }

  .feature-eyebrow {
    margin-top: 1.5rem;
  }

  .feature-card h3 {
    margin: 1.35rem 0 0;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    font-weight: 650;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .feature-eyebrow + h3 {
    margin-top: 0.5rem;
  }

  .feature-body {
    max-width: 58ch;
    margin: 0.7rem 0 0;
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.75;
  }

  .feature-stat {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.45rem;
    margin: auto 0 0;
    padding-top: 1.5rem;
    color: var(--link);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .change-path {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr auto;
    align-items: center;
    gap: 0.7rem;
    width: min(100%, 28rem);
    margin-top: auto;
    padding-top: 3rem;
  }

  .change-path span {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgba(110, 103, 248, 0.28);
    border-radius: 0.8rem;
    color: var(--link);
    background: var(--bg);
  }

  .change-path i {
    height: 1px;
    background: var(--border);
  }

  .format-cloud,
  .provider-cloud {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    margin-top: auto;
    padding-top: 1.5rem;
  }

  .format-cloud code {
    padding: 0.45rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 0.65rem;
    color: var(--link);
    background: var(--bg);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .provider-cloud {
    gap: 0.75rem;
  }

  .provider-cloud .vendor-mark {
    width: 3.5rem;
    height: 3.5rem;
  }

  @media (hover: hover) {
    .feature-card:hover {
      border-color: rgba(110, 103, 248, 0.42);
      box-shadow: 0 1.5rem 3.5rem rgba(70, 53, 188, 0.1);
      transform: translateY(-0.3rem);
    }
  }

  .landing-workflow {
    padding-block: clamp(4.5rem, 9vw, 7rem);
    border-block: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .workflow-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    align-items: center;
    gap: clamp(2.5rem, 7vw, 6rem);
  }

  .workflow-copy {
    display: grid;
    gap: 1.25rem;
  }

  .workflow-link {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.45rem;
    color: var(--link);
    font-size: 0.85rem;
    font-weight: 750;
  }

  .workflow-code {
    min-width: 0;
    overflow: hidden;
    filter: drop-shadow(0 1.5rem 2.5rem rgba(70, 53, 188, 0.11));
  }

  .landing-cta {
    width: min(100% - 2rem, 80rem);
    margin-inline: auto;
