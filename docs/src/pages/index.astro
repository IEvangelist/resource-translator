    }
    to {
      transform: translate3d(0, 0, 0) scale(1);
    }
  }
</style>

<script>
  let landingObserver: IntersectionObserver | undefined;

  function setupLandingReveals() {
    const elements = Array.from(
      document.querySelectorAll<HTMLElement>("[data-landing-reveal]"),
    );

    landingObserver?.disconnect();
    if (elements.length === 0) return;

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (reduceMotion || !("IntersectionObserver" in window)) {
      elements.forEach((element) => {
        element.dataset.revealState = "visible";
      });
      return;
    }

    landingObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const element = entry.target as HTMLElement;
          element.dataset.revealState = "visible";
          observer.unobserve(element);
        });
      },
      {
        rootMargin: "0px 0px -10% 0px",
        threshold: 0.12,
      },
    );
    elements.forEach((element) => {
      element.dataset.revealState = "hidden";
      landingObserver?.observe(element);
    });
  }

  setupLandingReveals();
  document.addEventListener("astro:page-load", setupLandingReveals);
  document.addEventListener("astro:before-preparation", () => {
    landingObserver?.disconnect();
  });
</script>
