---
import { Icon } from "astro-icon/components";
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import locales from "../data/azure-locales.json";
import enMessages from "../content/i18n/messages.en.json";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, link, strong } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "translations");

type Messages = typeof enMessages;
// Widen with optional bcp47 so accessing card.locale.bcp47 typechecks
// uniformly across all locales (only the few non-BCP-47 service codes
// declare it in azure-locales.json).
type Locale = (typeof locales)[number] & { bcp47?: string };

// Build-time eager glob of every translated messages.<locale>.json. The
// translate-docs workflow lands these via PR; once merged, the next docs
// build picks them up automatically.
const modules = import.meta.glob<{ default: Messages }>(
  "../content/i18n/messages.*.json",
  { eager: true },
);

function lookup(code: string): Messages | null {
  const key = `../content/i18n/messages.${code}.json`;
  const mod = modules[key];
  return mod ? mod.default : null;
}

interface Card {
  locale: Locale;
  messages: Messages | null;
  translated: boolean;
}

const cards: Card[] = locales
  .slice()
  .sort((a, b) => a.englishName.localeCompare(b.englishName))
  .map((locale) => ({
    locale,
    messages: lookup(locale.code),
    translated: lookup(locale.code) !== null,
  }));

const translatedCount = cards.filter((c) => c.translated).length;
const totalCount = cards.length;
const sourceCard: Card = {
  locale: { code: "en", englishName: "English", nativeName: "English", rtl: false },
  messages: enMessages,
  translated: true,
};

const workflowName = "translate-docs";
const workflowUrl =
  "https://github.com/IEvangelist/resource-translator/blob/main/.github/workflows/translate-docs.yml";
const statusText =
  translatedCount === totalCount ? copy.statusComplete : copy.statusPending;
const statusValues = {
  translatedCount: strong(translatedCount.toLocaleString("en-US")),
  pendingCount: (totalCount - translatedCount).toLocaleString("en-US"),
  workflowName: code(workflowName),
};
const howItWorksStepOrder = ["source", "workflow", "fanOut", "pullRequest"] as const;
---

<DocLayout title={copy.title} locale={locale} slug="translations">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.heroTitle}
    icon="lucide:languages"
    lede={copy.lede}
  />

  <div
    class="not-prose mb-8 flex flex-wrap items-center gap-3 rounded-xl border border-(--border) bg-(--bg-elevated) p-4 text-sm"
  >
    <span
      class="inline-flex items-center gap-1.5 rounded-md bg-(--color-brand-600) px-2.5 py-1 font-semibold text-white"
    >
      <Icon name="lucide:globe" class="size-3.5" />
      <LocalizedText
        text={copy.localeCountLabel}
        values={{ count: totalCount.toLocaleString("en-US") }}
      />
    </span>
    <span class="text-(--fg-muted)">
      <LocalizedText text={statusText} values={statusValues} />
    </span>
    <a
      class="ml-auto inline-flex items-center gap-1 text-sm font-medium"
      href="https://github.com/IEvangelist/resource-translator/actions/workflows/translate-docs.yml"
      rel="noopener"
      target="_blank"
    >
      <Icon name="lucide:external-link" class="size-3.5" />
      {copy.viewWorkflowRuns}
    </a>
  </div>

  <div class="not-prose mb-6">
    <label class="block text-sm font-semibold text-(--fg)" for="locale-search">
      {copy.filter}
    </label>
    <input
      id="locale-search"
      type="search"
      placeholder={copy.filterPlaceholder}
      autocomplete="off"
      class="mt-1 w-full rounded-lg border border-(--border) bg-(--bg) px-3 py-2 text-sm shadow-sm focus-visible:border-(--color-brand-500)"
    />
  </div>

  <h2 class="not-prose mt-12 mb-4 text-xl font-semibold tracking-tight">
    <Icon
      name="lucide:flag"
      class="mr-1 inline size-5 align-text-bottom text-(--color-warm-600)"
    />
    {copy.source}
  </h2>

  <article
    class="not-prose mb-10 rounded-2xl border-2 border-(--color-brand-500)/40 bg-(--bg-elevated) p-5 shadow-sm"
    data-locale-card
    data-search-haystack={`${sourceCard.locale.code} ${sourceCard.locale.englishName} ${sourceCard.locale.nativeName} english source`}
    lang={sourceCard.locale.code}
  >
    <header class="mb-3 flex items-baseline justify-between gap-3">
      <div>
        <p class="text-base font-bold text-(--fg)">{sourceCard.locale.englishName}</p>
        <p class="text-sm text-(--fg-muted)">{sourceCard.locale.nativeName}</p>
      </div>
      <code
        class="rounded-md bg-(--bg-elevated) px-2 py-0.5 text-xs font-mono text-(--fg-muted)"
      >
        {sourceCard.locale.code}
      </code>
    </header>
    <p class="text-base leading-relaxed text-(--fg)">
      {sourceCard.messages!.phrases.greeting}
    </p>
    <p class="mt-1 text-sm text-(--fg-muted)">
      {sourceCard.messages!.tagline}
    </p>
  </article>

  <h2 class="not-prose mt-12 mb-4 text-xl font-semibold tracking-tight">
    <Icon
      name="lucide:globe"
      class="mr-1 inline size-5 align-text-bottom text-(--color-accent-600)"
    />
    {copy.machineTranslations}
  </h2>

  <div
    class="not-prose grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
    id="locale-grid"
  >
    {
      cards.map((card) => (
        <article
          class:list={[
            "group rounded-xl border bg-(--bg-elevated) p-4 transition-shadow hover:shadow-md",
            card.translated
              ? "border-(--border)"
              : "border-dashed border-(--border) opacity-70",
          ]}
          data-locale-card
          data-translated={card.translated ? "true" : "false"}
          data-search-haystack={`${card.locale.code} ${card.locale.englishName} ${card.locale.nativeName}`}
          lang={card.locale.bcp47 ?? card.locale.code}
          dir={card.locale.rtl ? "rtl" : "ltr"}
        >
          <header class="mb-2 flex items-baseline justify-between gap-2">
            <div class="min-w-0">
              <p class="truncate text-sm font-semibold text-(--fg)" dir="ltr">
                {card.locale.englishName}
              </p>
              <p class="truncate text-xs text-(--fg-muted)">
                {card.locale.nativeName}
              </p>
            </div>
            <code
              class="flex-none rounded bg-(--bg) px-1.5 py-0.5 text-[10px] font-mono text-(--fg-muted)"
              dir="ltr"
            >
              {card.locale.code}
            </code>
          </header>
          {card.translated ? (
            <>
              <p class="text-sm leading-relaxed text-(--fg)">
                {card.messages!.phrases.greeting}
              </p>
              <p class="mt-1 text-xs text-(--fg-muted)">
                {card.messages!.tagline}
              </p>
              {card.messages!.phrases.thank_you && (
                <p class="mt-2 text-[11px] italic text-(--fg-muted)">
                  {card.messages!.phrases.thank_you}
                </p>
              )}
            </>
          ) : (
            <p
              class="flex items-center gap-1.5 text-xs italic text-(--fg-muted)"
              dir="ltr"
            >
              <Icon name="lucide:hourglass" class="size-3.5 flex-none" />
              <LocalizedText
                text={copy.translationPending}
                values={{ workflowName: code(workflowName) }}
              />
            </p>
          )}
        </article>
      ))
    }
  </div>

  <p
    id="locale-empty"
    hidden
    class="not-prose mt-6 rounded-lg border border-dashed border-(--border) bg-(--bg-elevated) p-6 text-center text-sm text-(--fg-muted)"
  >
    {copy.noLocales}
  </p>

  <h2 class="mt-16">{copy.howItWorks.heading}</h2>
  <ol>
    {
      howItWorksStepOrder.map((step) => (
        <li>
          <LocalizedText
            text={copy.howItWorks.steps[step]}
            values={{
              messagesPath: code("docs/src/content/i18n/messages.en.json"),
              workflowLink: link(".github/workflows/translate-docs.yml", workflowUrl, {
                external: true,
              }),
              thisAction: strong(copy.howItWorks.thisActionLabel),
              configPath: code(".github/resource-translator.yml"),
              messagesLocaleJson: code("messages.<locale>.json"),
            }}
          />
        </li>
      ))
    }
  </ol>

  <p class="mt-8 text-sm text-(--fg-muted)">
    {copy.poweredBy}
  </p>
</DocLayout>

<script>
  function bindLocaleSearch() {
    const input = document.getElementById("locale-search") as HTMLInputElement | null;
    const empty = document.getElementById("locale-empty") as HTMLElement | null;
    if (!input || input.dataset.bound === "1") return;
    input.dataset.bound = "1";
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-locale-card]"),
    );
    input.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      for (const card of cards) {
        const haystack = (card.dataset.searchHaystack ?? "").toLowerCase();
        const match = q === "" || haystack.includes(q);
        card.hidden = !match;
        if (match) visible++;
      }
      if (empty) empty.hidden = visible !== 0 || q === "";
    });
  }
  bindLocaleSearch();
  document.addEventListener("astro:page-load", bindLocaleSearch);
</script>
