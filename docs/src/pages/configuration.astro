---
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, link, type LocalizedReplacements } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "configuration");

const yaml = `# .github/resource-translator.yml
sourceLocale: en
toLocales:
  - fr
  - de
  - es
include:
  - "src/**/*.en.json"
  - "apps/**/*.en.resx"
exclude:
  - "**/__tests__/**"
glossary:
  Acme: Contoso
  Octocat: Octocat   # keep brand names verbatim

# Domain / industry — uses an Azure Custom Translator category trained on
# your tone and vocabulary. Leave unset for the general model.
categoryId: my-custom-translator-category

# Translator request shape — most users can ignore these.
textType: plain                  # plain | html
profanityAction: NoAction        # NoAction | Marked | Deleted
profanityMarker: Asterisk        # Asterisk | Tag (only when profanityAction == Marked)
allowFallback: true              # false fails when the categoryId has no deployment

apiVersion: "3.0"

# Resilience — Translator returns 429 under load. Defaults are usually
# fine; tune only if your runs are large enough to hit them.
maxRetries: 5
retryBackoffMs: 30000             # cap on any single backoff sleep (ms)

# Placeholder protection. ON by default — wraps tokens like {{name}},
# {0}, %s, \${var} into sentinels before translation and restores them
# on the way back. Set false only when source intentionally contains
# placeholder-shaped literals.
protectPlaceholders: true
customPlaceholderPatterns:
  - "<<.+?>>"                     # any extra token syntax you use

# Per-key opt-out. Keys matching any glob are dropped from the request
# and pass through with the source value preserved.
noTranslatePatterns:
  - "errors.code.*"
  - "brands.*"
`;

type LocalizedCell = {
  text: string;
  values?: LocalizedReplacements;
};

type FieldRow = {
  field: LocalizedCell;
  type: LocalizedCell;
  notes: LocalizedCell;
};

const customTranslatorOverviewUrl =
  "https://learn.microsoft.com/azure/ai-services/translator/custom-translator/overview";
const customTranslatorConceptsUrl =
  "https://learn.microsoft.com/azure/ai-services/translator/custom-translator/concepts/customization";

const fieldRows: FieldRow[] = [
  {
    field: { text: "{sourceLocale}", values: { sourceLocale: code("sourceLocale") } },
    type: { text: "string" },
    notes: {
      text: copy.fieldReference.fields.sourceLocale,
      values: {
        sourceLocale: code("sourceLocale"),
        fromLocale: code("from=<locale>"),
      },
    },
  },
  {
    field: { text: "{toLocales}", values: { toLocales: code("toLocales") } },
    type: { text: "string[]" },
    notes: { text: copy.fieldReference.fields.toLocales },
  },
  {
    field: {
      text: "{include} / {exclude}",
      values: { include: code("include"), exclude: code("exclude") },
    },
    type: { text: "string[]" },
    notes: { text: copy.fieldReference.fields.includeExclude },
  },
  {
    field: { text: "{glossary}", values: { glossary: code("glossary") } },
    type: { text: "map<string,string>" },
    notes: {
      text: copy.fieldReference.fields.glossary,
      values: { cpp: code("C++"), dotnet: code(".NET") },
    },
  },
  {
    field: { text: "{categoryId}", values: { categoryId: code("categoryId") } },
    type: { text: "string" },
    notes: {
      text: copy.fieldReference.fields.categoryId,
      values: {
        customTranslatorLink: link("Custom Translator", customTranslatorConceptsUrl, {
          external: true,
        }),
        categoryQuery: code("?category=..."),
      },
    },
  },
  {
    field: { text: "{textType}", values: { textType: code("textType") } },
    type: {
      text: "{plain} | {html}",
      values: { plain: code('"plain"'), html: code('"html"') },
    },
    notes: {
      text: copy.fieldReference.fields.textType,
      values: { plain: code("plain"), html: code("html") },
    },
  },
  {
    field: {
      text: "{profanityAction}",
      values: { profanityAction: code("profanityAction") },
    },
    type: {
      text: "{noAction} | {marked} | {deleted}",
      values: {
        noAction: code('"NoAction"'),
        marked: code('"Marked"'),
        deleted: code('"Deleted"'),
      },
    },
    notes: { text: copy.fieldReference.fields.profanityAction },
  },
  {
    field: {
      text: "{profanityMarker}",
      values: { profanityMarker: code("profanityMarker") },
    },
    type: {
      text: "{asterisk} | {tag}",
      values: { asterisk: code('"Asterisk"'), tag: code('"Tag"') },
    },
    notes: {
      text: copy.fieldReference.fields.profanityMarker,
      values: { profanityAction: code("profanityAction"), marked: code('"Marked"') },
    },
  },
  {
    field: { text: "{allowFallback}", values: { allowFallback: code("allowFallback") } },
    type: { text: "boolean" },
    notes: {
      text: copy.fieldReference.fields.allowFallback,
      values: { false: code("false"), categoryId: code("categoryId") },
    },
  },
  {
    field: { text: "{apiVersion}", values: { apiVersion: code("apiVersion") } },
    type: { text: "string" },
    notes: {
      text: copy.fieldReference.fields.apiVersion,
      values: { version: code("3.0") },
    },
  },
  {
    field: { text: "{maxRetries}", values: { maxRetries: code("maxRetries") } },
    type: { text: "integer" },
    notes: {
      text: copy.fieldReference.fields.maxRetries,
      values: {
        statusCodes: code("408, 425, 429, 500, 502, 503, 504"),
        defaultRetries: code("5"),
        totalCalls: code("1 + maxRetries"),
      },
    },
  },
  {
    field: {
      text: "{retryBackoffMs}",
      values: { retryBackoffMs: code("retryBackoffMs") },
    },
    type: { text: "integer" },
    notes: {
      text: copy.fieldReference.fields.retryBackoffMs,
      values: { defaultBackoff: code("30000"), retryAfter: code("Retry-After") },
    },
  },
  {
    field: {
      text: "{protectPlaceholders}",
      values: { protectPlaceholders: code("protectPlaceholders") },
    },
    type: { text: "boolean" },
    notes: {
      text: copy.fieldReference.fields.protectPlaceholders,
      values: {
        true: code("true"),
        mustache: code("{{name}}"),
        jsVar: code("${var}"),
        indexZero: code("{0}"),
        numberFormat: code("{0:N2}"),
        printf: code("%s"),
        positionalPrintf: code("%1$s"),
      },
    },
  },
  {
    field: {
      text: "{customPlaceholderPatterns}",
      values: { customPlaceholderPatterns: code("customPlaceholderPatterns") },
    },
    type: { text: "string[]" },
    notes: {
      text: copy.fieldReference.fields.customPlaceholderPatterns,
      values: { angleToken: code("<<.+?>>") },
    },
  },
  {
    field: {
      text: "{noTranslatePatterns}",
      values: { noTranslatePatterns: code("noTranslatePatterns") },
    },
    type: { text: "string[]" },
    notes: {
      text: copy.fieldReference.fields.noTranslatePatterns,
      values: {
        resxName: code("name"),
        poMsgid: code("msgid"),
        xliffId: code("id"),
      },
    },
  },
];

const loadingStepOrder = ["actionInputs", "config", "precedence", "validation"] as const;
---

<DocLayout title={copy.title} locale={locale} slug="configuration">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.heroTitle}
    icon="lucide:settings-2"
    lede={copy.lede}
  />
  <p>
    <LocalizedText
      text={copy.intro}
      values={{ configPath: code("configPath") }}
    />
  </p>

  <h2>{copy.schemaHeading}</h2>
  <Code code={yaml} lang="yaml" title=".github/resource-translator.yml" />

  <h2 id="field-reference">{copy.fieldReference.heading}</h2>
  <table>
    <caption class="sr-only">{copy.fieldReference.caption}</caption>
    <thead>
      <tr>
        <th>{copy.fieldReference.columns.field}</th>
        <th>{copy.fieldReference.columns.type}</th>
        <th>{copy.fieldReference.columns.notes}</th>
      </tr>
    </thead>
    <tbody>
      {
        fieldRows.map((row) => (
          <tr>
            <td>
              <LocalizedText text={row.field.text} values={row.field.values} />
            </td>
            <td>
              <LocalizedText text={row.type.text} values={row.type.values} />
            </td>
            <td>
              <LocalizedText text={row.notes.text} values={row.notes.values} />
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.loadingOrder.heading}</h2>
  <ol>
    {
      loadingStepOrder.map((key) => (
        <li>
          <LocalizedText
            text={copy.loadingOrder.steps[key]}
            values={{
              configPath: code("configPath"),
              invalidEnum: code("profanityAction: Mask"),
            }}
          />
        </li>
      ))
    }
  </ol>

  <h2>{copy.tone.heading}</h2>
  <p>{copy.tone.body}</p>
  <ul>
    <li>
      <strong>{copy.tone.industryLabel}</strong>{" "}
      <LocalizedText
        text={copy.tone.industryBody}
        values={{
          categoryId: code("categoryId"),
          customTranslatorLink: link("Custom Translator", customTranslatorOverviewUrl, {
            external: true,
          }),
        }}
      />
    </li>
    <li>
      <strong>{copy.tone.surfaceLabel}</strong>{" "}
      <LocalizedText
        text={copy.tone.surfaceBody}
        values={{
          glossaryLink: link(copy.tone.glossaryLinkLabel, "#field-reference"),
          profanityAction: code("profanityAction"),
        }}
      />
    </li>
  </ul>
</DocLayout>
