---
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, link, type LocalizedReplacements } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "faq");

const azureSdkUrl = "https://www.npmjs.com/package/@azure-rest/ai-translation-text";
const corePipelineUrl = "https://www.npmjs.com/package/@azure/core-rest-pipeline";
const issueUrl =
  "https://github.com/IEvangelist/resource-translator/issues/new/choose";

type FaqItem = {
  heading: string;
  body: string;
  values?: LocalizedReplacements;
};

const questions: FaqItem[] = [
  {
    heading: copy.questions.azure.heading,
    body: copy.questions.azure.body,
    values: {
      azureSdkLink: link(code("@azure-rest/ai-translation-text"), azureSdkUrl, {
        external: true,
      }),
      corePipelineLink: link(code("@azure/core-rest-pipeline"), corePipelineUrl, {
        external: true,
      }),
      statusCodes: code("408/429/5xx"),
      axios: code("axios"),
    },
  },
  {
    heading: copy.questions.tone.heading,
    body: copy.questions.tone.body,
    values: {
      glossaryLink: link(
        copy.questions.tone.glossaryLinkLabel,
        "./configuration#field-reference",
      ),
      customTranslatorLink: link(
        copy.questions.tone.customTranslatorLinkLabel,
        "./configuration#field-reference",
      ),
      profanityAction: code("profanityAction"),
    },
  },
  {
    heading: copy.questions.duplicateFiles.heading,
    body: copy.questions.duplicateFiles.body,
    values: {
      paths: code("paths"),
      sourceGlob: code("**/*.en.resx"),
      githubToken: code("GITHUB_TOKEN"),
    },
  },
  {
    heading: copy.questions.offline.heading,
    body: copy.questions.offline.body,
    values: { dryRunTrue: code("dryRun: true") },
  },
  {
    heading: copy.questions.node.heading,
    body: copy.questions.node.body,
    values: { nodeRuntime: code("node24") },
  },
  {
    heading: copy.questions.dist.heading,
    body: copy.questions.dist.body,
    values: {
      distDir: code("dist/"),
      distBuild: code("dist-build"),
      mainBranch: code("main"),
      distCheck: code("dist-check"),
    },
  },
  {
    heading: copy.questions.formats.heading,
    body: copy.questions.formats.body,
    values: {
      resx: code(".resx"),
      xliff: code(".xliff"),
      po: code(".po"),
      json: code(".json"),
      ini: code(".ini"),
      restext: code(".restext"),
      issueLink: link(copy.questions.formats.issueLinkLabel, issueUrl, {
        external: true,
      }),
    },
  },
];
---

<DocLayout title={copy.title} locale={locale} slug="faq">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.heroTitle}
    icon="lucide:circle-help"
    lede={copy.lede}
  />

  {
    questions.map((question) => (
      <>
        <h2>
          <LocalizedText text={question.heading} values={question.values} />
        </h2>
        <p>
          <LocalizedText text={question.body} values={question.values} />
        </p>
      </>
    ))
  }
</DocLayout>
