---
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";

const pr = `- id: translate
  uses: IEvangelist/resource-translator@v3
  with:
    sourceLocale: en
    subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
    endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
    region: \${{ secrets.TRANSLATOR_REGION }}

- if: steps.translate.outputs.has-new-translations == 'true'
  uses: peter-evans/create-pull-request@v7
  with:
    branch: machine-translation
    title: \${{ steps.translate.outputs.summary-title }}
    body: \${{ steps.translate.outputs.summary-details }}
    labels: localization
`;

const monorepo = `with:
  sourceLocale: en
  include: |
    apps/web/**/*.en.resx
    packages/shared/**/*.en.json
  exclude: |
    **/dist/**
    **/__tests__/**
`;

const glossary = `glossary:
  Acme: Contoso
  Octocat: Octocat
  ".NET": ".NET"
  "C++": "C++"
`;

const customCat = `with:
  sourceLocale: en
  subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
  endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
  categoryId: 1234abcd-5678-90ef-...
`;

const dryRun = `with:
  dryRun: true
  failOnError: false
`;
---

<DocLayout title="Recipes">
  <h1>Recipes</h1>

  <h2>Open a pull request after each run</h2>
  <Code code={pr} lang="yaml" title="translate.yml (excerpt)" />

  <h2>Monorepos: scope translation per package</h2>
  <Code code={monorepo} lang="yaml" />

  <h2>Glossary for brand names and product terms</h2>
  <p>Drop a <code>.github/resource-translator.yml</code> into the repo:</p>
  <Code code={glossary} lang="yaml" title=".github/resource-translator.yml" />
  <p>
    Glossary terms are applied <em>after</em> translation, so the
    machine-translated output keeps your preferred branding even when the model
    swapped it for a synonym.
  </p>

  <h2>Custom Translator category</h2>
  <Code code={customCat} lang="yaml" />

  <h2>Dry run before turning the workflow on</h2>
  <Code code={dryRun} lang="yaml" />
  <p>
    The action still emits summary outputs and a step summary, but no files
    are written. Combine with <code>failOnError: false</code> to surface every
    issue as a warning while you iterate.
  </p>
</DocLayout>
