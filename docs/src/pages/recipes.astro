---
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";
import PageHero from "../components/PageHero.astro";

const pr = `- id: translate
  uses: IEvangelist/resource-translator@v3
  with:
    sourceLocale: en
    subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
    endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
    region: \${{ secrets.TRANSLATOR_REGION }}

- if: steps.translate.outputs.has-new-translations == 'true'
  uses: peter-evans/create-pull-request@v7
  with:
    branch: machine-translation
    title: \${{ steps.translate.outputs.summary-title }}
    body: \${{ steps.translate.outputs.summary-details }}
    labels: localization
`;

const monorepo = `with:
  sourceLocale: en
  include: |
    apps/web/**/*.en.resx
    packages/shared/**/*.en.json
  exclude: |
    **/dist/**
    **/__tests__/**
`;

const glossary = `glossary:
  Acme: Contoso
  Octocat: Octocat
  ".NET": ".NET"
  "C++": "C++"
`;

const customCat = `with:
  sourceLocale: en
  subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
  endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
  categoryId: 1234abcd-5678-90ef-...
`;

const tone = `# .github/resource-translator.yml
# Industry / domain — choose your tone via a Custom Translator category
categoryId: legal-en

# Treat profanity strictly for content aimed at younger audiences
profanityAction: Marked
profanityMarker: Tag

# Fail the run rather than silently fall back to the general model
allowFallback: false
`;

const dryRun = `with:
  dryRun: true
  failOnError: false
`;
---

<DocLayout title="Recipes">
  <PageHero
    slot="hero"
    eyebrow="Cookbook"
    title="Recipes"
    icon="lucide:wand-sparkles"
    lede="Common patterns for shipping translations: monorepos, glossaries, custom categories, dry runs, and tone control."
  />

  <h2>Open a pull request after each run</h2>
  <Code code={pr} lang="yaml" title="translate.yml (excerpt)" />

  <h2>Monorepos: scope translation per package</h2>
  <Code code={monorepo} lang="yaml" />

  <h2>Glossary for brand names and product terms</h2>
  <p>Drop a <code>.github/resource-translator.yml</code> into the repo:</p>
  <Code code={glossary} lang="yaml" title=".github/resource-translator.yml" />
  <p>
    Glossary terms are applied <em>after</em> translation, so the
    machine-translated output keeps your preferred branding even when the model
    swapped it for a synonym.
  </p>

  <h2>Custom Translator category (industry / domain)</h2>
  <Code code={customCat} lang="yaml" />
  <p>
    Train an Azure
    <a
      href="https://learn.microsoft.com/azure/ai-services/translator/custom-translator/overview"
      rel="noopener"
      target="_blank">Custom Translator</a
    > category on a corpus that captures your industry vocabulary and tone (legal,
    medical, marketing, internal-engineering, etc.) and pass its ID via <code
      >categoryId</code
    >. This is the strongest tone lever Azure offers.
  </p>

  <h2>Tone control + strict fallback</h2>
  <Code code={tone} lang="yaml" title=".github/resource-translator.yml" />
  <p>
    Combine a Custom Translator <code>categoryId</code> with <code
      >profanityAction</code
    > and <code>allowFallback: false</code> to enforce a consistent voice and
    fail the workflow if the chosen category does not have a deployment for one
    of your target locales.
  </p>

  <h2>Dry run before turning the workflow on</h2>
  <Code code={dryRun} lang="yaml" />
  <p>
    The action still emits summary outputs and a step summary, but no files
    are written. Combine with <code>failOnError: false</code> to surface every
    issue as a warning while you iterate.
  </p>
</DocLayout>

