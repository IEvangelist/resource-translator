---
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, em, link } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "recipes");

const pr = `- id: translate
  uses: IEvangelist/resource-translator@v3
  with:
    sourceLocale: en
    subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
    endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
    region: \${{ secrets.TRANSLATOR_REGION }}

- if: steps.translate.outputs.has-new-translations == 'true'
  uses: peter-evans/create-pull-request@v7
  with:
    branch: machine-translation
    title: \${{ steps.translate.outputs.summary-title }}
    body: \${{ steps.translate.outputs.summary-details }}
    labels: localization
`;

const monorepo = `with:
  sourceLocale: en
  include: |
    apps/web/**/*.en.resx
    packages/shared/**/*.en.json
  exclude: |
    **/dist/**
    **/__tests__/**
`;

const glossary = `glossary:
  Acme: Contoso
  Octocat: Octocat
  ".NET": ".NET"
  "C++": "C++"
`;

const customCat = `with:
  sourceLocale: en
  subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
  endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
  categoryId: 1234abcd-5678-90ef-...
`;

const tone = `# .github/resource-translator.yml
# Industry / domain — choose your tone via a Custom Translator category
categoryId: legal-en

# Treat profanity strictly for content aimed at younger audiences
profanityAction: Marked
profanityMarker: Tag

# Fail the run rather than silently fall back to the general model
allowFallback: false
`;

const dryRun = `with:
  dryRun: true
  failOnError: false
`;

const customTranslatorUrl =
  "https://learn.microsoft.com/azure/ai-services/translator/custom-translator/overview";
---

<DocLayout title={copy.title} locale={locale} slug="recipes">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.title}
    icon="lucide:wand-sparkles"
    lede={copy.lede}
  />

  <h2>{copy.sections.pullRequest.heading}</h2>
  <Code code={pr} lang="yaml" title="translate.yml (excerpt)" />

  <h2>{copy.sections.monorepo.heading}</h2>
  <Code code={monorepo} lang="yaml" />

  <h2>{copy.sections.glossary.heading}</h2>
  <p>
    <LocalizedText
      text={copy.sections.glossary.intro}
      values={{ configPath: code(".github/resource-translator.yml") }}
    />
  </p>
  <Code code={glossary} lang="yaml" title=".github/resource-translator.yml" />
  <p>
    <LocalizedText
      text={copy.sections.glossary.body}
      values={{ after: em(copy.sections.glossary.afterLabel) }}
    />
  </p>

  <h2>{copy.sections.customCategory.heading}</h2>
  <Code code={customCat} lang="yaml" />
  <p>
    <LocalizedText
      text={copy.sections.customCategory.body}
      values={{
        customTranslatorLink: link("Custom Translator", customTranslatorUrl, {
          external: true,
        }),
        categoryId: code("categoryId"),
      }}
    />
  </p>

  <h2>{copy.sections.tone.heading}</h2>
  <Code code={tone} lang="yaml" title=".github/resource-translator.yml" />
  <p>
    <LocalizedText
      text={copy.sections.tone.body}
      values={{
        categoryId: code("categoryId"),
        profanityAction: code("profanityAction"),
        allowFallbackFalse: code("allowFallback: false"),
      }}
    />
  </p>

  <h2>{copy.sections.dryRun.heading}</h2>
  <Code code={dryRun} lang="yaml" />
  <p>
    <LocalizedText
      text={copy.sections.dryRun.body}
      values={{ failOnErrorFalse: code("failOnError: false") }}
    />
  </p>
</DocLayout>
