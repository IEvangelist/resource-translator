---
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, em, link, strong, type LocalizedReplacements } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "changelog");

type ChangelogItem = {
  text: string;
  values?: LocalizedReplacements;
};

const changelogUrl =
  "https://github.com/IEvangelist/resource-translator/blob/main/CHANGELOG.md";

const commonValues = {
  include: code("include"),
  exclude: code("exclude"),
  configPath: code("configPath"),
  categoryId: code("categoryId"),
  apiVersion: code("apiVersion"),
  dryRun: code("dryRun"),
  failOnError: code("failOnError"),
  textType: code("textType"),
  profanityAction: code("profanityAction"),
  profanityMarker: code("profanityMarker"),
  allowFallback: code("allowFallback"),
  maxRetries: code("maxRetries"),
  retryBackoffMs: code("retryBackoffMs"),
  retryAfter: code("Retry-After"),
  mustache: code("{{name}}"),
  jsVar: code("${var}"),
  indexZero: code("{0}"),
  numberFormat: code("{0:N2}"),
  printf: code("%s"),
  positionalPrintf: code("%1$s"),
  protectPlaceholders: code("protectPlaceholders"),
  customPlaceholderPatterns: code("customPlaceholderPatterns"),
  noTranslatePatterns: code("noTranslatePatterns"),
  resxName: code("name"),
  poMsgid: code("msgid"),
  xliffId: code("id"),
  coreSummary: code("core.summary"),
};

const v3Items: ChangelogItem[] = [
  {
    text: copy.v3.items.runtime,
    values: {
      nodeRuntime: code("node24"),
      breaking: strong(copy.v3.labels.breaking),
    },
  },
  { text: copy.v3.items.newInputs, values: commonValues },
  {
    text: copy.v3.items.sourceLocale,
    values: { fromLocale: code("from=<locale>") },
  },
  {
    text: copy.v3.items.resilience,
    values: {
      ...commonValues,
      label: strong(copy.v3.labels.resilience),
      statusCodes: code("408, 425, 429, 500, 502, 503, 504"),
      issue: em(copy.v3.issueLabels.closes46),
    },
  },
  {
    text: copy.v3.items.placeholderProtection,
    values: {
      ...commonValues,
      label: strong(copy.v3.labels.placeholderProtection),
      issue: em(copy.v3.issueLabels.tightens16),
    },
  },
  {
    text: copy.v3.items.perKeyOptOut,
    values: {
      ...commonValues,
      label: strong(copy.v3.labels.perKeyOptOut),
      issue: em(copy.v3.issueLabels.closes35),
    },
  },
  {
    text: copy.v3.items.repoConfig,
    values: { configPath: code(".github/resource-translator.yml") },
  },
  { text: copy.v3.items.glossary, values: commonValues },
  { text: copy.v3.items.tooling },
  { text: copy.v3.items.audit },
  { text: copy.v3.items.docsSite },
  {
    text: copy.v3.items.docsAccessibility,
    values: {
      label: strong(copy.v3.labels.docsAccessibility),
      backToTop: code("Back to top"),
      inert: code("inert"),
      ariaHidden: code("aria-hidden"),
      formatsAstro: code("formats.astro"),
      lang: code("lang"),
      nya: code("nya→ny"),
      lug: code("lug→lg"),
      run: code("run→rn"),
      documentation: code("Documentation"),
      inputs: code("inputs"),
      configuration: code("configuration"),
    },
  },
  {
    text: copy.v3.items.inlineCode,
    values: {
      label: strong(copy.v3.labels.inlineCodeStyling),
      codeElement: code("<code>"),
    },
  },
  { text: copy.v3.items.automation },
];
---

<DocLayout title={copy.title} locale={locale} slug="changelog">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.title}
    icon="lucide:history"
    lede={copy.lede}
  />
  <p>
    <LocalizedText
      text={copy.fullRecord}
      values={{
        changelogLink: link(copy.fullRecordLinkLabel, changelogUrl, {
          external: true,
        }),
      }}
    />
  </p>

  <h2>{copy.v3.heading}</h2>
  <ul>
    {
      v3Items.map((item) => (
        <li>
          <LocalizedText text={item.text} values={item.values} />
        </li>
      ))
    }
  </ul>

  <h2>{copy.v2.heading}</h2>
  <ul>
    <li>{copy.v2.gitHistory}</li>
  </ul>
</DocLayout>
