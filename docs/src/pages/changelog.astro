---
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, em, link, strong, type LocalizedReplacements } from "../i18n/rich-text";
import { releaseHistory } from "../data/release-history";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "changelog");

type ChangelogItem = {
  text: string;
  values?: LocalizedReplacements;
};

type ReleaseSection = {
  version: string;
  date?: string;
  /** Rich, localized bullets (recent releases). */
  localizedItems?: ChangelogItem[];
  /** Plain-text bullets (historical releases). */
  plainItems?: readonly string[];
};

const changelogUrl =
  "https://github.com/IEvangelist/resource-translator/blob/main/CHANGELOG.md";

const fixedLabel = strong(copy.fixedLabel);

const commonValues = {
  include: code("include"),
  exclude: code("exclude"),
  configPath: code("configPath"),
  categoryId: code("categoryId"),
  apiVersion: code("apiVersion"),
  dryRun: code("dryRun"),
  failOnError: code("failOnError"),
  textType: code("textType"),
  profanityAction: code("profanityAction"),
  profanityMarker: code("profanityMarker"),
  allowFallback: code("allowFallback"),
  maxRetries: code("maxRetries"),
  retryBackoffMs: code("retryBackoffMs"),
  retryAfter: code("Retry-After"),
  mustache: code("{{name}}"),
  jsVar: code("${var}"),
  indexZero: code("{0}"),
  numberFormat: code("{0:N2}"),
  printf: code("%s"),
  positionalPrintf: code("%1$s"),
  protectPlaceholders: code("protectPlaceholders"),
  customPlaceholderPatterns: code("customPlaceholderPatterns"),
  noTranslatePatterns: code("noTranslatePatterns"),
  changeDetection: code("changeDetection"),
  statePath: code("statePath"),
  snapshotOnly: code("snapshotOnly"),
  smart: code("smart"),
  disabled: code("disabled"),
  false: code("false"),
  stateManifest: code(".github/resource-translator-state.json"),
  resxName: code("name"),
  poMsgid: code("msgid"),
  xliffId: code("id"),
  coreSummary: code("core.summary"),
};

const v300Items: ChangelogItem[] = [
  {
    text: copy.v3.items.runtime,
    values: {
      nodeRuntime: code("node24"),
      breaking: strong(copy.v3.labels.breaking),
    },
  },
  { text: copy.v3.items.newInputs, values: commonValues },
  {
    text: copy.v3.items.sourceLocale,
    values: { fromLocale: code("from=<locale>") },
  },
  {
    text: copy.v3.items.resilience,
    values: {
      ...commonValues,
      label: strong(copy.v3.labels.resilience),
      statusCodes: code("408, 425, 429, 500, 502, 503, 504"),
      issue: em(copy.v3.issueLabels.closes46),
    },
  },
  {
    text: copy.v3.items.placeholderProtection,
    values: {
      ...commonValues,
      label: strong(copy.v3.labels.placeholderProtection),
      issue: em(copy.v3.issueLabels.tightens16),
    },
  },
  {
    text: copy.v3.items.perKeyOptOut,
    values: {
      ...commonValues,
      label: strong(copy.v3.labels.perKeyOptOut),
      issue: em(copy.v3.issueLabels.closes35),
    },
  },
  {
    text: copy.v3.items.repoConfig,
    values: { configPath: code(".github/resource-translator.yml") },
  },
  { text: copy.v3.items.glossary, values: commonValues },
  { text: copy.v3.items.tooling },
  { text: copy.v3.items.audit },
  { text: copy.v3.items.docsSite },
  {
    text: copy.v3.items.docsAccessibility,
    values: {
      label: strong(copy.v3.labels.docsAccessibility),
      backToTop: code("Back to top"),
      inert: code("inert"),
      ariaHidden: code("aria-hidden"),
      formatsAstro: code("formats.astro"),
      lang: code("lang"),
      nya: code("nya→ny"),
      lug: code("lug→lg"),
      run: code("run→rn"),
      documentation: code("Documentation"),
      inputs: code("inputs"),
      configuration: code("configuration"),
    },
  },
  {
    text: copy.v3.items.inlineCode,
    values: {
      label: strong(copy.v3.labels.inlineCodeStyling),
      codeElement: code("<code>"),
    },
  },
  { text: copy.v3.items.automation },
];

const configureAwsCredentialsUrl =
  "https://github.com/aws-actions/configure-aws-credentials";

const multiVendorValues = {
  ...commonValues,
  azure: "Azure AI Translator",
  aws: "AWS Translate",
  google: "Google Cloud Translation",
  provider: code("provider"),
  azureValue: code("azure"),
  awsSdk: code("@aws-sdk/client-translate"),
  googleSdk: code("@google-cloud/translate"),
  configureAwsCredentials: link(
    "aws-actions/configure-aws-credentials",
    configureAwsCredentialsUrl,
    { external: true },
  ),
  awsAccessKeyId: code("awsAccessKeyId"),
  awsSecretAccessKey: code("awsSecretAccessKey"),
  awsRegion: code("awsRegion"),
  awsRegionEnv: code("AWS_REGION"),
  googleApiKey: code("googleApiKey"),
  googleCredentials: code("googleCredentials"),
  googleProjectId: code("googleProjectId"),
  format: code("format"),
  subscriptionKey: code("subscriptionKey"),
  endpoint: code("endpoint"),
  region: code("region"),
  actionYml: code("action.yml"),
};

const v310Items: ChangelogItem[] = [
  {
    text: copy.v31.items.multiVendor,
    values: {
      ...multiVendorValues,
      label: strong(copy.v31.labels.multiVendor),
    },
  },
  { text: copy.v31.items.aws, values: multiVendorValues },
  { text: copy.v31.items.google, values: multiVendorValues },
  { text: copy.v31.items.inputs, values: multiVendorValues },
  {
    text: copy.v31.items.intentMapping,
    values: {
      ...multiVendorValues,
      label: strong(copy.v31.labels.intentMapping),
    },
  },
  { text: copy.v31.items.azureRelaxed, values: multiVendorValues },
  { text: copy.v31.items.docs, values: multiVendorValues },
];

const releases: ReleaseSection[] = [
  {
    version: "Unreleased",
    localizedItems: [
      {
        text: copy.releases.unreleasedSmartChangeDetection,
        values: commonValues,
      },
    ],
  },
  {
    version: "3.1.0",
    date: "2026-07-10",
    localizedItems: v310Items,
  },
  {
    version: "3.0.2",
    date: "2026-07-10",
    localizedItems: [
      {
        text: copy.releases.v302,
        values: {
          label: fixedLabel,
          apiVersion: code("api-version=3.0"),
          translate: code("/translate"),
          languages: code("/languages"),
          code: code("400074"),
        },
      },
    ],
  },
  {
    version: "3.0.1",
    date: "2026-07-10",
    localizedItems: [
      {
        text: copy.releases.v301,
        values: {
          label: fixedLabel,
          translate: code("/translate"),
          textItem: code("{ text }"),
          inputs: code("{ inputs }"),
        },
      },
    ],
  },
  {
    version: "3.0.0",
    date: "2026-07-08",
    localizedItems: v300Items,
  },
  ...releaseHistory.map((release) => ({
    version: release.version,
    date: release.date,
    plainItems: release.changes,
  })),
];
---

<DocLayout title={copy.title} locale={locale} slug="changelog">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.title}
    icon="lucide:history"
    lede={copy.lede}
  />
  <p>
    <LocalizedText
      text={copy.fullRecord}
      values={{
        changelogLink: link(copy.fullRecordLinkLabel, changelogUrl, {
          external: true,
        }),
      }}
    />
  </p>

  <h2>{copy.releasesHeading}</h2>
  {
    releases.map((release) => (
      <section>
        <h3>
          {release.version}
          {release.date && (
            <>
              {" "}
              — <time datetime={release.date}>{release.date}</time>
            </>
          )}
        </h3>
        <ul>
          {release.localizedItems?.map((item) => (
            <li>
              <LocalizedText text={item.text} values={item.values} />
            </li>
          ))}
          {release.plainItems?.map((change) => (
            <li>{change}</li>
          ))}
        </ul>
      </section>
    ))
  }
</DocLayout>
