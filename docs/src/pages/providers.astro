---
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import ReferenceCards from "../components/ReferenceCards.astro";
import type { ReferenceItem } from "../components/ReferenceCards.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, link } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "providers");

const configureAwsCredentialsUrl =
  "https://github.com/aws-actions/configure-aws-credentials";
const azureDocsUrl =
  "https://learn.microsoft.com/en-us/azure/ai-services/translator/";
const azureTranslateApiUrl =
  "https://learn.microsoft.com/en-us/azure/ai-services/translator/text-translation/reference/v3/translate";
const azureCustomTranslatorUrl =
  "https://learn.microsoft.com/en-us/azure/ai-services/translator/custom-translator/overview";
const azureLanguageSupportUrl =
  "https://learn.microsoft.com/en-us/azure/ai-services/translator/language-support";
const awsDocsUrl = "https://docs.aws.amazon.com/translate/latest/dg/what-is.html";
const awsTranslateApiUrl =
  "https://docs.aws.amazon.com/translate/latest/APIReference/API_TranslateText.html";
const awsFormalityUrl =
  "https://docs.aws.amazon.com/translate/latest/dg/customizing-translations-formality.html";
const awsBrevityUrl =
  "https://docs.aws.amazon.com/translate/latest/dg/customizing-translations-brevity.html";
const awsTerminologyUrl =
  "https://docs.aws.amazon.com/translate/latest/dg/how-custom-terminology.html";
const awsParallelDataUrl =
  "https://docs.aws.amazon.com/translate/latest/dg/customizing-translations-parallel-data.html";
const awsLanguageSupportUrl =
  "https://docs.aws.amazon.com/translate/latest/dg/what-is-languages.html";
const googleDocsUrl = "https://docs.cloud.google.com/translate/docs";
const googleSetupUrl = "https://docs.cloud.google.com/translate/docs/setup";
const googleTranslateTextUrl =
  "https://docs.cloud.google.com/translate/docs/translate-text";
const googleLanguageSupportUrl =
  "https://docs.cloud.google.com/translate/docs/languages";

const awsWorkflow = `permissions:
  id-token: write # for aws-actions/configure-aws-credentials OIDC
  contents: write
  pull-requests: write

jobs:
  translate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5

      - uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::123456789012:role/gh-actions-translate
          aws-region: us-east-1

      - id: translator
        uses: IEvangelist/resource-translator@v3
        with:
          provider: |
            aws:
              region: us-east-1 # or rely on AWS_REGION from the step above
              formality: FORMAL
              brevity: true
          sourceLocale: en
          toLocales: '["es","fr","de"]'
`;

const googleWorkflow = `jobs:
  translate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5

      - id: translator
        uses: IEvangelist/resource-translator@v3
        with:
          provider: |
            google:
              # Provide EITHER a service-account JSON credential...
              credentials: \${{ secrets.GCP_TRANSLATE_CREDENTIALS }}
              # ...OR an API key:
              # apiKey: \${{ secrets.GCP_TRANSLATE_API_KEY }}
              model: nmt
          sourceLocale: en
          toLocales: '["es","fr","de"]'
`;

const azureWorkflow = `jobs:
  translate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5

      - id: translator
        uses: IEvangelist/resource-translator@v3
        with:
          provider: |
            azure:
              subscriptionKey: \${{ secrets.TRANSLATOR_KEY }}
              endpoint: \${{ secrets.TRANSLATOR_ENDPOINT }}
              region: \${{ secrets.TRANSLATOR_REGION }}
          sourceLocale: en
          toLocales: '["es","fr","de"]'
`;

const comparisonRows = [
  {
    name: copy.comparison.azure.name,
    value: copy.comparison.azure.value,
    sdk: "@azure-rest/ai-translation-text",
    credentials: copy.comparison.azure.credentials,
  },
  {
    name: copy.comparison.aws.name,
    value: copy.comparison.aws.value,
    sdk: "@aws-sdk/client-translate",
    credentials: copy.comparison.aws.credentials,
  },
  {
    name: copy.comparison.google.name,
    value: copy.comparison.google.value,
    sdk: "@google-cloud/translate",
    credentials: copy.comparison.google.credentials,
  },
];

const comparisonCards: ReferenceItem[] = comparisonRows.map((row) => ({
  title: row.name,
  description: { text: row.credentials },
  meta: [
    {
      label: copy.comparison.columns.value,
      value: { text: "{value}", values: { value: code(row.value) } },
    },
    {
      label: copy.comparison.columns.sdk,
      value: { text: "{sdk}", values: { sdk: code(row.sdk) } },
    },
  ],
}));

const mappingRows = [
  { input: "textType", ...copy.mapping.rows.textType },
  { input: "profanityAction", ...copy.mapping.rows.profanityAction },
  { input: "categoryId", ...copy.mapping.rows.categoryId },
  { input: "allowFallback", ...copy.mapping.rows.allowFallback },
  { input: "awsFormality", ...copy.mapping.rows.awsFormality },
  { input: "awsBrevity", ...copy.mapping.rows.awsBrevity },
  { input: "awsTerminologyNames", ...copy.mapping.rows.awsTerminologyNames },
  { input: "awsParallelDataNames", ...copy.mapping.rows.awsParallelDataNames },
  { input: "googleModel", ...copy.mapping.rows.googleModel },
  { input: "googleApiEndpoint", ...copy.mapping.rows.googleApiEndpoint },
];

const mappingCards: ReferenceItem[] = mappingRows.map((row) => ({
  title: row.input,
  titleCode: true,
  meta: [
    { label: copy.mapping.columns.azure, value: { text: row.azure } },
    { label: copy.mapping.columns.aws, value: { text: row.aws } },
    { label: copy.mapping.columns.google, value: { text: row.google } },
  ],
}));

const azureDocLinks = [
  { href: azureDocsUrl, label: copy.azure.docs.overview },
  { href: azureTranslateApiUrl, label: copy.azure.docs.translateApi },
  { href: azureCustomTranslatorUrl, label: copy.azure.docs.customTranslator },
  { href: azureLanguageSupportUrl, label: copy.azure.docs.languages },
];
const awsDocLinks = [
  { href: awsDocsUrl, label: copy.aws.docs.overview },
  { href: awsTranslateApiUrl, label: copy.aws.docs.translateTextApi },
  { href: awsFormalityUrl, label: copy.aws.docs.formality },
  { href: awsBrevityUrl, label: copy.aws.docs.brevity },
  { href: awsTerminologyUrl, label: copy.aws.docs.terminology },
  { href: awsParallelDataUrl, label: copy.aws.docs.parallelData },
  { href: awsLanguageSupportUrl, label: copy.aws.docs.languages },
];
const googleDocLinks = [
  { href: googleDocsUrl, label: copy.google.docs.overview },
  { href: googleSetupUrl, label: copy.google.docs.setup },
  { href: googleTranslateTextUrl, label: copy.google.docs.translateText },
  { href: googleLanguageSupportUrl, label: copy.google.docs.languages },
];
---

<DocLayout title={copy.title} locale={locale} slug="providers">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.title}
    icon="lucide:globe"
    lede={copy.lede}
  />

  <p>
    <LocalizedText
      text={copy.backwardCompatible}
      values={{ provider: code("provider"), azure: code("azure") }}
    />
  </p>

  <h2>{copy.selecting.title}</h2>
  <p>
    <LocalizedText
      text={copy.selecting.body}
      values={{
        provider: code("provider"),
        azure: code("azure"),
        aws: code("aws"),
        google: code("google"),
      }}
    />
  </p>

  <h2>{copy.comparison.title}</h2>
  <ReferenceCards items={comparisonCards} ariaLabel={copy.comparison.caption} />

  <h2>{copy.azure.title}</h2>
  <p>
    <LocalizedText
      text={copy.azure.body}
      values={{
        subscriptionKey: code("subscriptionKey"),
        endpoint: code("endpoint"),
        region: code("region"),
        azureBlock: code("provider.azure"),
      }}
    />
  </p>
  <h3>{copy.azure.docsHeading}</h3>
  <ul class="provider-doc-links">
    {
      azureDocLinks.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))
    }
  </ul>
  <Code code={azureWorkflow} lang="yaml" title=".github/workflows/translate.yml" />

  <h2>{copy.aws.title}</h2>
  <p>
    <LocalizedText
      text={copy.aws.body}
      values={{
        sdk: code("@aws-sdk/client-translate"),
        configureAwsCredentials: link(
          "aws-actions/configure-aws-credentials",
          configureAwsCredentialsUrl,
          { external: true },
        ),
        awsAccessKeyId: code("awsAccessKeyId"),
        awsSecretAccessKey: code("awsSecretAccessKey"),
        awsRegion: code("awsRegion"),
        awsRegionEnv: code("AWS_REGION"),
        awsFormality: code("awsFormality"),
        awsBrevity: code("awsBrevity"),
        awsTerminologyNames: code("awsTerminologyNames"),
        awsParallelDataNames: code("awsParallelDataNames"),
      }}
    />
  </p>
  <h3>{copy.aws.docsHeading}</h3>
  <ul class="provider-doc-links">
    {
      awsDocLinks.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))
    }
  </ul>
  <h3>{copy.aws.oidcTitle}</h3>
  <Code code={awsWorkflow} lang="yaml" title=".github/workflows/translate.yml" />
  <p>
    <LocalizedText
      text={copy.aws.keysNote}
      values={{
        configureAwsCredentials: code("aws-actions/configure-aws-credentials"),
        awsAccessKeyId: code("awsAccessKeyId"),
        awsSecretAccessKey: code("awsSecretAccessKey"),
        awsRegion: code("awsRegion"),
        secrets: code("secrets"),
      }}
    />
  </p>

  <h2>{copy.google.title}</h2>
  <p>
    <LocalizedText
      text={copy.google.body}
      values={{
        sdk: code("@google-cloud/translate"),
        googleApiKey: code("googleApiKey"),
        googleCredentials: code("googleCredentials"),
        googleProjectId: code("googleProjectId"),
        googleModel: code("googleModel"),
        googleApiEndpoint: code("googleApiEndpoint"),
        googleAutoRetry: code("googleAutoRetry"),
      }}
    />
  </p>
  <h3>{copy.google.docsHeading}</h3>
  <ul class="provider-doc-links">
    {
      googleDocLinks.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))
    }
  </ul>
  <Code code={googleWorkflow} lang="yaml" title=".github/workflows/translate.yml" />

  <h2>{copy.mapping.title}</h2>
  <p>{copy.mapping.body}</p>
  <ReferenceCards items={mappingCards} ariaLabel={copy.mapping.caption} />

  <h2>{copy.locales.title}</h2>
  <p>
    <LocalizedText
      text={copy.locales.body}
      values={{
        azureCode: code("zh-Hans"),
        awsCode: code("zh"),
        googleCode: code("zh-CN"),
        toLocales: code("toLocales"),
      }}
    />
  </p>
</DocLayout>
