---
import { Code } from "astro-expressive-code/components";
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "contributing");

const cmd = `git clone https://github.com/IEvangelist/resource-translator
cd resource-translator
npm install
npm run verify   # lint + format:check + test + build
`;

const parserStepOrder = ["fixture", "implement", "register", "extension", "tests"] as const;
const parserStepValues = {
  testDataDir: code("__tests__/data/"),
  parserInterface: code("TranslationFileParser"),
  parse: code("parse"),
  format: code("format"),
  applyTranslations: code("applyTranslations"),
  toTranslatableTextMap: code("toTranslatableTextMap"),
  factoryFile: code("translation-file-parser-factory.ts"),
  translationFileSchemes: code("translationFileSchemes"),
  finderFile: code("translation-file-finder.ts"),
};
---

<DocLayout title={copy.title} locale={locale} slug="contributing">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.title}
    icon="lucide:hand-heart"
    lede={copy.lede}
  />

  <h2>{copy.localDevelopment.heading}</h2>
  <Code code={cmd} lang="bash" />

  <h2>{copy.addingParser.heading}</h2>
  <ol>
    {
      parserStepOrder.map((step) => (
        <li>
          <LocalizedText
            text={copy.addingParser.steps[step]}
            values={parserStepValues}
          />
        </li>
      ))
    }
  </ol>

  <h2>{copy.coverage.heading}</h2>
  <p>{copy.coverage.body}</p>

  <h2>{copy.docsSite.heading}</h2>
  <p>
    <LocalizedText
      text={copy.docsSite.body}
      values={{
        docsDir: code("docs/"),
        npmInstall: code("npm install"),
        npmRunDev: code("npm run dev"),
        pagesWorkflow: code("pages.yml"),
      }}
    />
  </p>
</DocLayout>
