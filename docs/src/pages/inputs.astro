---
import DocLayout from "../layouts/DocLayout.astro";
import LocalizedText from "../components/LocalizedText.astro";
import PageHero from "../components/PageHero.astro";
import { defaultLocale } from "../i18n/locales";
import { getPageMessages } from "../i18n/messages";
import { code, em, link, type LocalizedReplacements } from "../i18n/rich-text";

const { locale = defaultLocale } = Astro.props;
const copy = getPageMessages(locale, "inputs");

type LocalizedCell = {
  text: string;
  values?: LocalizedReplacements;
};

type InputRow = {
  name: string;
  default?: LocalizedCell;
  description: LocalizedCell;
};

const customTranslatorUrl =
  "https://learn.microsoft.com/azure/ai-services/translator/custom-translator/overview";

const noneDefault = { text: "{value}", values: { value: em(copy.defaults.none) } };

const requiredRows: InputRow[] = [
  {
    name: "sourceLocale",
    description: {
      text: copy.requiredInputs.items.sourceLocale,
      values: {
        en: code("en"),
        sourceGlob: code("**/*.en.resx"),
        fromLocale: code("from=<locale>"),
      },
    },
  },
];

const providerRows: InputRow[] = [
  {
    name: "provider",
    default: { text: "{value}", values: { value: code("azure") } },
    description: {
      text: copy.providerInputs.items.provider,
      values: { azure: code("azure"), aws: code("aws"), google: code("google") },
    },
  },
  {
    name: "subscriptionKey",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.subscriptionKey,
      values: { azure: code("azure"), secrets: code("secrets") },
    },
  },
  {
    name: "endpoint",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.endpoint,
      values: {
        endpointUrl: code("https://api.cognitive.microsofttranslator.com/"),
        azure: code("azure"),
      },
    },
  },
  {
    name: "awsAccessKeyId",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.awsAccessKeyId,
      values: { awsSecretAccessKey: code("awsSecretAccessKey"), secrets: code("secrets") },
    },
  },
  {
    name: "awsSecretAccessKey",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.awsSecretAccessKey,
      values: { awsAccessKeyId: code("awsAccessKeyId"), secrets: code("secrets") },
    },
  },
  {
    name: "awsSessionToken",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.awsSessionToken,
      values: { secrets: code("secrets") },
    },
  },
  {
    name: "awsRegion",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.awsRegion,
      values: {
        aws: code("aws"),
        regionExample: code("us-east-1"),
        awsRegionEnv: code("AWS_REGION"),
      },
    },
  },
  {
    name: "googleApiKey",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.googleApiKey,
      values: {
        google: code("google"),
        googleCredentials: code("googleCredentials"),
        secrets: code("secrets"),
      },
    },
  },
  {
    name: "googleCredentials",
    default: noneDefault,
    description: {
      text: copy.providerInputs.items.googleCredentials,
      values: {
        google: code("google"),
        googleApiKey: code("googleApiKey"),
        secrets: code("secrets"),
      },
    },
  },
  {
    name: "googleProjectId",
    default: noneDefault,
    description: { text: copy.providerInputs.items.googleProjectId },
  },
];

const optionalRows: InputRow[] = [
  {
    name: "region",
    default: noneDefault,
    description: { text: copy.optionalInputs.items.region },
  },
  {
    name: "toLocales",
    default: {
      text: "{value}",
      values: { value: em(copy.defaults.allSupported) },
    },
    description: {
      text: copy.optionalInputs.items.toLocales,
      values: { jsonArray: code('["fr","de"]') },
    },
  },
  {
    name: "include",
    default: noneDefault,
    description: { text: copy.optionalInputs.items.include },
  },
  {
    name: "exclude",
    default: noneDefault,
    description: { text: copy.optionalInputs.items.exclude },
  },
  {
    name: "configPath",
    default: {
      text: "{value}",
      values: { value: code(".github/resource-translator.yml") },
    },
    description: { text: copy.optionalInputs.items.configPath },
  },
  {
    name: "changeDetection",
    default: { text: "{value}", values: { value: code("smart") } },
    description: {
      text: copy.optionalInputs.items.changeDetection,
      values: {
        smart: code("smart"),
        disabled: code("disabled"),
        false: code("false"),
      },
    },
  },
  {
    name: "statePath",
    default: {
      text: "{value}",
      values: { value: code(".github/resource-translator-state.json") },
    },
    description: {
      text: copy.optionalInputs.items.statePath,
      values: {
        defaultPath: code(".github/resource-translator-state.json"),
      },
    },
  },
  {
    name: "snapshotOnly",
    default: { text: "{value}", values: { value: code("false") } },
    description: {
      text: copy.optionalInputs.items.snapshotOnly,
      values: {
        true: code("true"),
        statePath: code("statePath"),
      },
    },
  },
  {
    name: "dryRun",
    default: { text: "{value}", values: { value: code("false") } },
    description: {
      text: copy.optionalInputs.items.dryRun,
      values: { true: code("true") },
    },
  },
  {
    name: "failOnError",
    default: { text: "{value}", values: { value: code("true") } },
    description: {
      text: copy.optionalInputs.items.failOnError,
      values: { true: code("true"), false: code("false") },
    },
  },
];

const translatorRows: InputRow[] = [
  {
    name: "categoryId",
    default: { text: "{value}", values: { value: em("general") } },
    description: {
      text: copy.translatorInputs.items.categoryId,
      values: {
        customTranslatorLink: link("Custom Translator", customTranslatorUrl, {
          external: true,
        }),
        categoryQuery: code("?category=..."),
      },
    },
  },
  {
    name: "textType",
    default: { text: "{value}", values: { value: code("plain") } },
    description: {
      text: copy.translatorInputs.items.textType,
      values: { plain: code("plain"), html: code("html") },
    },
  },
  {
    name: "profanityAction",
    default: { text: "{value}", values: { value: code("NoAction") } },
    description: {
      text: copy.translatorInputs.items.profanityAction,
      values: {
        noAction: code("NoAction"),
        marked: code("Marked"),
        deleted: code("Deleted"),
      },
    },
  },
  {
    name: "profanityMarker",
    default: { text: "{value}", values: { value: code("Asterisk") } },
    description: {
      text: copy.translatorInputs.items.profanityMarker,
      values: {
        asterisk: code("Asterisk"),
        tag: code("Tag"),
        profanityAction: code("profanityAction"),
        marked: code("Marked"),
      },
    },
  },
  {
    name: "allowFallback",
    default: {
      text: "{value}",
      values: { value: em(copy.defaults.translatorDefaultTrue) },
    },
    description: {
      text: copy.translatorInputs.items.allowFallback,
      values: { false: code("false"), categoryId: code("categoryId") },
    },
  },
  {
    name: "apiVersion",
    default: { text: "{value}", values: { value: code("3.0") } },
    description: { text: copy.translatorInputs.items.apiVersion },
  },
];

const resilienceRows: InputRow[] = [
  {
    name: "maxRetries",
    default: { text: "{value}", values: { value: code("5") } },
    description: {
      text: copy.resilienceInputs.items.maxRetries,
      values: {
        statusCodes: code("408, 425, 429, 500, 502, 503, 504"),
        totalCalls: code("1 + maxRetries"),
      },
    },
  },
  {
    name: "retryBackoffMs",
    default: { text: "{value}", values: { value: code("30000") } },
    description: {
      text: copy.resilienceInputs.items.retryBackoffMs,
      values: { retryAfter: code("Retry-After") },
    },
  },
  {
    name: "protectPlaceholders",
    default: { text: "{value}", values: { value: code("true") } },
    description: {
      text: copy.resilienceInputs.items.protectPlaceholders,
      values: {
        true: code("true"),
        mustache: code("{{name}}"),
        jsVar: code("${var}"),
        indexZero: code("{0}"),
        numberFormat: code("{0:N2}"),
        printf: code("%s"),
        positionalPrintf: code("%1$s"),
      },
    },
  },
  {
    name: "customPlaceholderPatterns",
    default: noneDefault,
    description: {
      text: copy.resilienceInputs.items.customPlaceholderPatterns,
      values: { angleToken: code("<<.+?>>") },
    },
  },
  {
    name: "noTranslatePatterns",
    default: noneDefault,
    description: {
      text: copy.resilienceInputs.items.noTranslatePatterns,
      values: {
        resxName: code("name"),
        poMsgid: code("msgid"),
        xliffId: code("id"),
      },
    },
  },
];

const outputRows: InputRow[] = [
  {
    name: "summary-title",
    description: {
      text: copy.outputs.items.summaryTitle,
      values: {
        summaryExample: em(
          "Machine-translated 320 files, a total of 5,418 translations",
        ),
      },
    },
  },
  {
    name: "summary-details",
    description: { text: copy.outputs.items.summaryDetails },
  },
  {
    name: "has-new-translations",
    description: {
      text: copy.outputs.items.hasNewTranslations,
      values: { trueString: code("'true'") },
    },
  },
];
---

<DocLayout title={copy.title} locale={locale} slug="inputs">
  <PageHero
    slot="hero"
    eyebrow={copy.eyebrow}
    title={copy.title}
    icon="lucide:file-text"
    lede={copy.lede}
  />
  <p>
    <LocalizedText
      text={copy.configurationIntro}
      values={{ configurationLink: link(copy.configurationLinkLabel, "./configuration") }}
    />
  </p>

  <h2>{copy.requiredInputs.heading}</h2>
  <table>
    <caption class="sr-only">{copy.requiredInputs.caption}</caption>
    <thead>
      <tr><th>{copy.columns.name}</th><th>{copy.columns.description}</th></tr>
    </thead>
    <tbody>
      {
        requiredRows.map((row) => (
          <tr>
            <td><code>{row.name}</code></td>
            <td>
              <LocalizedText
                text={row.description.text}
                values={row.description.values}
              />
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.providerInputs.heading}</h2>
  <p>
    <LocalizedText
      text={copy.providerInputs.intro}
      values={{
        provider: code("provider"),
        providersLink: link(copy.title, "./providers"),
      }}
    />
  </p>
  <table>
    <caption class="sr-only">{copy.providerInputs.caption}</caption>
    <thead>
      <tr>
        <th>{copy.columns.name}</th>
        <th>{copy.columns.default}</th>
        <th>{copy.columns.description}</th>
      </tr>
    </thead>
    <tbody>
      {
        providerRows.map((row) => (
          <tr>
            <td><code>{row.name}</code></td>
            <td>
              {row.default && (
                <LocalizedText text={row.default.text} values={row.default.values} />
              )}
            </td>
            <td>
              <LocalizedText
                text={row.description.text}
                values={row.description.values}
              />
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.optionalInputs.heading}</h2>
  <table>
    <caption class="sr-only">{copy.optionalInputs.caption}</caption>
    <thead>
      <tr>
        <th>{copy.columns.name}</th>
        <th>{copy.columns.default}</th>
        <th>{copy.columns.description}</th>
      </tr>
    </thead>
    <tbody>
      {
        optionalRows.map((row) => (
          <tr>
            <td><code>{row.name}</code></td>
            <td>
              {row.default && (
                <LocalizedText text={row.default.text} values={row.default.values} />
              )}
            </td>
            <td>
              <LocalizedText
                text={row.description.text}
                values={row.description.values}
              />
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.translatorInputs.heading}</h2>
  <p>{copy.translatorInputs.intro}</p>
  <table>
    <caption class="sr-only">{copy.translatorInputs.caption}</caption>
    <thead>
      <tr>
        <th>{copy.columns.name}</th>
        <th>{copy.columns.default}</th>
        <th>{copy.columns.description}</th>
      </tr>
    </thead>
    <tbody>
      {
        translatorRows.map((row) => (
          <tr>
            <td><code>{row.name}</code></td>
            <td>
              {row.default && (
                <LocalizedText text={row.default.text} values={row.default.values} />
              )}
            </td>
            <td>
              <LocalizedText
                text={row.description.text}
                values={row.description.values}
              />
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.resilienceInputs.heading}</h2>
  <p>
    <LocalizedText
      text={copy.resilienceInputs.intro}
      values={{ mustache: code("{{name}}"), indexZero: code("{0}") }}
    />
  </p>
  <table>
    <caption class="sr-only">{copy.resilienceInputs.caption}</caption>
    <thead>
      <tr>
        <th>{copy.columns.name}</th>
        <th>{copy.columns.default}</th>
        <th>{copy.columns.description}</th>
      </tr>
    </thead>
    <tbody>
      {
        resilienceRows.map((row) => (
          <tr>
            <td><code>{row.name}</code></td>
            <td>
              {row.default && (
                <LocalizedText text={row.default.text} values={row.default.values} />
              )}
            </td>
            <td>
              <LocalizedText
                text={row.description.text}
                values={row.description.values}
              />
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.outputs.heading}</h2>
  <table>
    <caption class="sr-only">{copy.outputs.caption}</caption>
    <thead>
      <tr><th>{copy.columns.name}</th><th>{copy.columns.description}</th></tr>
    </thead>
    <tbody>
      {
        outputRows.map((row) => (
          <tr>
            <td><code>{row.name}</code></td>
            <td>
              <LocalizedText
                text={row.description.text}
                values={row.description.values}
              />
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</DocLayout>
