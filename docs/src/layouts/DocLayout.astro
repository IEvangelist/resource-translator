---
import "../styles/tailwind.css";
import "@fontsource-variable/inter/wght.css";
import { ClientRouter } from "astro:transitions";
import { Icon } from "astro-icon/components";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import DocPager from "../components/DocPager.astro";
import BackToTop from "../components/BackToTop.astro";
import Toc from "../components/Toc.astro";
import TocMobile from "../components/TocMobile.astro";
import { getCommonMessages, getNavMessages } from "../i18n/messages";
import {
  allLocales,
  defaultLocale,
  toHtmlLang,
  toTextDirection,
} from "../i18n/locales";
import { localizedHref, slugFromPath, type PageSlug } from "../i18n/routes";

interface Props {
  title: string;
  description?: string;
  socialTitle?: string;
  socialDescription?: string;
  hideSidebar?: boolean;
  wide?: boolean;
  locale?: string;
  slug?: PageSlug;
}

const {
  title,
  description,
  socialTitle,
  socialDescription,
  hideSidebar = false,
  wide = false,
  locale = defaultLocale,
  slug = slugFromPath(Astro.url.pathname),
} = Astro.props;
const common = getCommonMessages(locale);
const nav = getNavMessages(locale);
const siteName = common.site.name;
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const desc =
  description ??
  common.site.defaultDescription;
const ogTitle = socialTitle ?? fullTitle;
const ogDescription = socialDescription ?? desc;
const baseHref = import.meta.env.BASE_URL.replace(/\/$/, "");
const faviconHref = `${baseHref}/favicon.svg`;
const htmlLang = toHtmlLang(locale);
const dir = toTextDirection(locale);
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(localizedHref(locale, slug), siteUrl).toString();
const ogImageUrl = new URL(`${baseHref}/og-image.png`, siteUrl).toString();
const ogImageAlt =
  title === siteName ? siteName : `${title} · ${siteName}`;
const alternates = allLocales.map((item) => ({
  lang: toHtmlLang(item.code),
  href: new URL(localizedHref(item.code, slug), siteUrl).toString(),
}));
---

<!doctype html>
<html lang={htmlLang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <meta data-pagefind-filter="locale[content]" content={locale} />
    <meta
      name="theme-color"
      content="#5b46d6"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1a1530"
      media="(prefers-color-scheme: dark)"
    />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={htmlLang.replace("-", "_")} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={canonicalUrl} />
    {
      alternates.map((alternate) => (
        <link
          rel="alternate"
          hreflang={alternate.lang}
          href={alternate.href}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(localizedHref(defaultLocale, slug), siteUrl).toString()}
    />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{fullTitle}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-(--bg-elevated) focus:px-3 focus:py-1.5 focus:text-sm focus:font-semibold focus:shadow-lg"
      >{common.skipToContent}</a
    >
    <Header
      hasSidebar={!hideSidebar}
      locale={locale}
      common={common}
      currentSlug={slug}
    />
    {
      hideSidebar ? (
        <main id="main" class="min-w-0">
          <slot />
        </main>
      ) : (
        <Fragment>
          <div
            class:list={[
              "mx-auto flex gap-12 px-4 py-10 sm:px-6",
              wide ? "max-w-7xl" : "max-w-7xl",
            ]}
          >
            <aside
              class="hidden w-56 flex-none lg:block"
              aria-label="Documentation navigation"
            >
              <div class="sticky top-24">
                <Sidebar locale={locale} nav={nav} currentSlug={slug} />
              </div>
            </aside>
            <main id="main" class="min-w-0 flex-1">
              <slot name="hero" />
              <TocMobile title={common.toc.title} />
              <article class="prose-rt">
                <slot />
              </article>
              <DocPager
                locale={locale}
                nav={nav}
                pager={common.pager}
                currentSlug={slug}
              />
            </main>
            <Toc title={common.toc.title} />
          </div>

          <div
            id="sidebar-drawer"
            role="dialog"
            aria-modal="true"
            aria-label={common.drawer.title}
            class="fixed inset-0 z-40 lg:hidden"
            hidden
          >
            <div
              data-drawer-overlay
              class="absolute inset-0 bg-black/50 backdrop-blur-sm"
            />
            <div
              class="absolute inset-y-0 left-0 flex w-full flex-col overflow-y-auto border-r border-(--border) bg-(--bg) shadow-2xl sm:w-80 sm:max-w-[85vw]"
            >
              <div class="flex items-center justify-between border-b border-(--border) px-4 py-3">
                  <span class="text-sm font-semibold">{common.drawer.title}</span>
                <button
                  type="button"
                  data-drawer-close
                  class="inline-flex size-9 items-center justify-center rounded-md border border-(--border) bg-(--bg-elevated) text-(--fg-muted) hover:text-(--fg)"
                  aria-label={common.drawer.close}
                >
                  <Icon name="lucide:x" class="size-4" />
                </button>
              </div>
              <div class="flex-1 px-3 py-4">
                <Sidebar locale={locale} nav={nav} currentSlug={slug} />
              </div>
            </div>
          </div>
        </Fragment>
      )
    }
    <BackToTop label={common.backToTop.label} />
    <Footer locale={locale} common={common} nav={nav} />

    <script>
      // Mobile sidebar drawer: open/close, focus management, ESC handling.
      // Re-binds on every navigation because ClientRouter swaps the body.
      function bindDrawer() {
        const btn = document.getElementById("sidebar-toggle");
        const drawer = document.getElementById("sidebar-drawer");
        if (!btn || !drawer) return;
        if ((drawer as any).__bound) return;
        (drawer as any).__bound = true;

        const overlay = drawer.querySelector<HTMLElement>(
          "[data-drawer-overlay]",
        );
        const closeBtn = drawer.querySelector<HTMLButtonElement>(
          "[data-drawer-close]",
        );
        const main = document.getElementById("main");

        const open = () => {
          drawer.hidden = false;
          btn.setAttribute("aria-expanded", "true");
          document.body.style.overflow = "hidden";
          if (main) main.setAttribute("inert", "");
          // Move focus into the drawer for screen readers.
          (
            closeBtn ||
            drawer.querySelector<HTMLElement>("a, button")
          )?.focus();
        };
        const close = () => {
          if (drawer.hidden) return;
          drawer.hidden = true;
          btn.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
          if (main) main.removeAttribute("inert");
          btn.focus();
        };

        btn.addEventListener("click", open);
        overlay?.addEventListener("click", close);
        closeBtn?.addEventListener("click", close);
        drawer.addEventListener("click", (e) => {
          // Close when a navigation link is selected.
          const target = e.target as HTMLElement;
          if (target.closest("a")) close();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && !drawer.hidden) close();
        });
        // Close before any client-side navigation.
        document.addEventListener("astro:before-preparation", close);
      }
      bindDrawer();
      document.addEventListener("astro:page-load", bindDrawer);
    </script>
  </body>
</html>

