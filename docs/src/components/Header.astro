---
import { Icon } from "astro-icon/components";
import Logo from "./Logo.astro";

interface Props {
  hasSidebar?: boolean;
}

const { hasSidebar = true } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const homeHref = base || "/";
const pagefindBase = base || "";
const pagefindScript = `${pagefindBase}/pagefind/pagefind.js`;
---

<header
  transition:persist
  class="sticky top-0 z-30 border-b border-(--border) bg-(--bg)/85 backdrop-blur-xl supports-[backdrop-filter]:bg-(--bg)/65"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3 sm:gap-4 sm:px-6"
  >
    <div class="flex items-center gap-2">
      {hasSidebar && (
        <button
          type="button"
          id="sidebar-toggle"
          class="inline-flex size-9 items-center justify-center rounded-md border border-(--border) bg-(--bg-elevated) text-(--fg-muted) hover:text-(--fg) lg:hidden"
          aria-label="Open navigation"
          aria-controls="sidebar-drawer"
          aria-expanded="false"
          hidden
        >
          <Icon name="lucide:menu" class="size-4" />
        </button>
      )}
      <a
        href={homeHref}
        class="group flex items-center gap-2.5 text-base font-semibold no-underline"
      >
        <Logo
          size={32}
          class="rounded-lg shadow-sm transition-transform group-hover:rotate-[-6deg]"
        />
        <span class="hidden sm:inline">Resource Translator</span>
      </a>
    </div>

    <div class="relative hidden flex-1 max-w-md md:block">
      <label class="sr-only" for="docs-search">Search docs</label>
      <div
        class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-(--fg-muted)"
      >
        <Icon name="lucide:search" class="size-4" />
      </div>
      <input
        id="docs-search"
        type="search"
        placeholder="Search documentation…"
        autocomplete="off"
        class="w-full rounded-md border border-(--border) bg-(--bg-elevated) py-2 pl-9 pr-3 text-sm placeholder-(--fg-muted) focus:border-(--color-brand-500) focus:outline-none focus:ring-2 focus:ring-(--color-brand-500)/40"
      />
      <div
        id="search-results"
        class="absolute right-0 left-0 z-40 mt-1 hidden max-h-[60vh] overflow-y-auto rounded-md border border-(--border) bg-(--bg-elevated) p-2 text-sm shadow-lg"
      >
      </div>
    </div>

    <div class="flex items-center gap-1.5">
      <button
        type="button"
        id="theme-toggle"
        class="inline-flex size-9 items-center justify-center rounded-md border border-(--border) bg-(--bg-elevated) text-(--fg-muted) hover:text-(--fg)"
        aria-label="Toggle theme"
      >
        <Icon name="lucide:sun" class="size-4 dark:hidden" />
        <Icon name="lucide:moon" class="size-4 hidden dark:block" />
      </button>
      <a
        href="https://github.com/IEvangelist/resource-translator"
        class="inline-flex size-9 items-center justify-center rounded-md border border-(--border) bg-(--bg-elevated) text-(--fg-muted) no-underline hover:text-(--fg)"
        rel="noopener"
        target="_blank"
        aria-label="GitHub repository"
      >
        <Icon name="simple-icons:github" class="size-4" />
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const apply = () => {
    const stored = localStorage.getItem("theme");
    const prefersDark = window.matchMedia(
      "(prefers-color-scheme: dark)",
    ).matches;
    const root = document.documentElement;
    const isDark = stored === "dark" || (!stored && prefersDark);
    root.classList.toggle("dark", isDark);
    // Keep `data-theme` in sync so Expressive Code's per-theme CSS rules
    // (keyed to [data-theme='catppuccin-mocha'|'catppuccin-latte'] via
    // ec.config.mjs) light up the correct token + chrome colors.
    root.setAttribute(
      "data-theme",
      isDark ? "catppuccin-mocha" : "catppuccin-latte",
    );
  };
  apply();
  document.addEventListener("astro:after-swap", apply);
</script>

<script>
  // Theme toggle (re-binds across view transitions)
  function bindToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn || (btn as any).__bound) return;
    (btn as any).__bound = true;
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle("dark");
      const next = isDark ? "dark" : "light";
      localStorage.setItem("theme", next);
      root.setAttribute(
        "data-theme",
        isDark ? "catppuccin-mocha" : "catppuccin-latte",
      );
    });
  }
  bindToggle();
  document.addEventListener("astro:page-load", bindToggle);

  // Hamburger button is rendered with `hidden` so server-rendered pages without
  // JS won't show a non-functional button. Reveal it as soon as the page loads.
  function showSidebarToggle() {
    const btn = document.getElementById("sidebar-toggle");
    if (btn && btn.hasAttribute("hidden") && document.getElementById("sidebar-drawer")) {
      btn.removeAttribute("hidden");
    }
  }
  showSidebarToggle();
  document.addEventListener("astro:page-load", showSidebarToggle);
</script>

<script is:inline define:vars={{ pagefindScript }}>
  function bindSearch() {
    const input = document.getElementById("docs-search");
    const resultsEl = document.getElementById("search-results");
    if (!input || !resultsEl || input.dataset.bound === "1") return;
    input.dataset.bound = "1";

    let pagefind = null;
    let loadAttempted = false;
    let debounceId;

    async function loadPagefind() {
      if (pagefind || loadAttempted) return pagefind;
      loadAttempted = true;
      try {
        pagefind = await import(/* @vite-ignore */ pagefindScript);
        await pagefind.options?.({ excerptLength: 24 });
      } catch (err) {
        console.warn(
          "Pagefind not available (run `npm run build` to generate it).",
          err,
        );
        pagefind = null;
      }
      return pagefind;
    }

    function escapeHtml(s) {
      return s.replace(
        /[&<>"']/g,
        (c) =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#39;",
          })[c],
      );
    }

    async function runSearch(q) {
      const pf = await loadPagefind();
      if (!pf) {
        resultsEl.innerHTML =
          '<div class="px-3 py-2 text-(--fg-muted)">Search index not available in dev. Run a production build.</div>';
        resultsEl.classList.remove("hidden");
        return;
      }
      const search = await pf.search(q);
      if (!search?.results?.length) {
        resultsEl.innerHTML =
          '<div class="px-3 py-2 text-(--fg-muted)">No results.</div>';
        resultsEl.classList.remove("hidden");
        return;
      }
      const top = await Promise.all(
        search.results.slice(0, 8).map((r) => r.data()),
      );
      resultsEl.innerHTML = top
        .map(
          (d) =>
            `<a href="${d.url}" class="block rounded-md px-3 py-2 hover:bg-(--bg) no-underline">
              <div class="font-medium">${escapeHtml(d.meta?.title || d.url)}</div>
              <div class="text-(--fg-muted) text-xs">${d.excerpt}</div>
            </a>`,
        )
        .join("");
      resultsEl.classList.remove("hidden");
    }

    input.addEventListener("input", (e) => {
      const q = e.target.value.trim();
      clearTimeout(debounceId);
      if (!q) {
        resultsEl.classList.add("hidden");
        resultsEl.innerHTML = "";
        return;
      }
      debounceId = setTimeout(() => runSearch(q), 120);
    });

    document.addEventListener("click", (e) => {
      if (!resultsEl.contains(e.target) && e.target !== input) {
        resultsEl.classList.add("hidden");
      }
    });
  }
  bindSearch();
  document.addEventListener("astro:page-load", bindSearch);
</script>


