<script>
  const ORBIT_ANCHOR = 144;
  const REWIND_DURATION = 340;
  const ROTATION_DURATION = 780;
  const STAGE_DURATION = 5600;

  let orbitCleanups: Array<() => void> = [];

  function modulo(value: number, divisor: number) {
    return ((value % divisor) + divisor) % divisor;
  }

  function setupTranslationOrbits() {
    orbitCleanups.forEach((cleanup) => cleanup());
    orbitCleanups = [];

    document
      .querySelectorAll<HTMLElement>("[data-translation-orbit]")
      .forEach((root) => {
        const nodes = Array.from(
          root.querySelectorAll<HTMLButtonElement>("[data-orbit-node]"),
        );
        const stages = Array.from(
          root.querySelectorAll<HTMLElement>("[data-orbit-stage]"),
        );
        const toggle = root.querySelector<HTMLButtonElement>(
          "[data-orbit-toggle]",
        );
        const toggleLabel = root.querySelector<HTMLElement>(
          "[data-orbit-toggle-label]",
        );
        const status = root.querySelector<HTMLElement>("[data-orbit-status]");
        const live = root.querySelector<HTMLElement>("[data-orbit-live]");

        if (
          nodes.length === 0 ||
          stages.length !== nodes.length ||
          !toggle ||
          !toggleLabel ||
          !status ||
          !live
        ) {
          return;
        }

        const controller = new AbortController();
        const reduceMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );
        const angleStep = 360 / nodes.length;
        const copy = {
          playing: root.dataset.copyPlaying ?? "",
          paused: root.dataset.copyPaused ?? "",
          reduced: root.dataset.copyReduced ?? "",
          pause: root.dataset.copyPause ?? "",
          resume: root.dataset.copyResume ?? "",
        };

        let rotationStep = 0;
        let activeIndex = 0;
        let autoplay = !reduceMotion.matches;
        let transitioning = false;
        let autoplayTimer: number | undefined;
        let rewindTimer: number | undefined;
        let rotationTimer: number | undefined;

        const clearTimers = () => {
          window.clearTimeout(autoplayTimer);
          window.clearTimeout(rewindTimer);
          window.clearTimeout(rotationTimer);
          autoplayTimer = undefined;
          rewindTimer = undefined;
          rotationTimer = undefined;
        };

        const updateStatus = () => {
          const reduced = reduceMotion.matches;
          root.dataset.reduced = String(reduced);
          root.dataset.autoplay = autoplay && !reduced ? "running" : "paused";
          status.textContent = reduced
            ? copy.reduced
            : autoplay
              ? copy.playing
              : copy.paused;
          toggle.setAttribute(
            "aria-label",
            autoplay ? copy.pause : copy.resume,
          );
          toggleLabel.textContent = autoplay ? copy.pause : copy.resume;
          toggle.hidden = reduced;
          live.setAttribute(
            "aria-live",
            autoplay && !reduced ? "off" : "polite",
          );
        };

        const updateNodes = () => {
          nodes.forEach((node, index) => {
            const angle = ORBIT_ANCHOR + (index - rotationStep) * angleStep;
            const relative = modulo(index - activeIndex, nodes.length);
            const distance = Math.min(relative, nodes.length - relative);
            const isActive = index === activeIndex;

            node.style.setProperty("--orbit-angle", `${angle}deg`);
            node.style.setProperty("--node-layer", String(8 - distance));
            node.dataset.active = String(isActive);
            node.setAttribute("aria-pressed", String(isActive));
          });
        };

        const updateStage = (index: number) => {
          activeIndex = index;
          stages.forEach((stage, stageIndex) => {
            const isActive = stageIndex === activeIndex;
            stage.dataset.active = String(isActive);
            stage.setAttribute("aria-hidden", String(!isActive));
          });

          if (!autoplay || reduceMotion.matches) {
            live.textContent = nodes[index]?.dataset.stageTitle ?? "";
          }
        };

        const scheduleNext = () => {
          window.clearTimeout(autoplayTimer);
          if (!autoplay || reduceMotion.matches || document.hidden) return;

          autoplayTimer = window.setTimeout(() => {
            transitionTo(modulo(activeIndex + 1, nodes.length), false);
          }, STAGE_DURATION);
        };

        const playActiveStage = (manualSelection: boolean) => {
          root.dataset.phase = "reset";
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              root.dataset.phase = "playing";
              transitioning = false;
              if (manualSelection) {
                autoplay = false;
                updateStatus();
                live.textContent = nodes[activeIndex]?.dataset.stageTitle ?? "";
              } else {
                scheduleNext();
              }
            });
          });
        };

        const transitionTo = (
          targetIndex: number,
          manualSelection: boolean,
        ) => {
          if (transitioning || targetIndex === activeIndex) {
            if (manualSelection && targetIndex === activeIndex) {
              autoplay = false;
              clearTimers();
              updateStatus();
            }
            return;
          }

          clearTimers();
          let delta = modulo(targetIndex - activeIndex, nodes.length);
          if (delta > nodes.length / 2) delta -= nodes.length;

          if (reduceMotion.matches) {
            rotationStep += delta;
            updateStage(targetIndex);
            updateNodes();
            autoplay = false;
            root.dataset.phase = "paused";
            updateStatus();
            return;
          }

          transitioning = true;
          root.dataset.phase = "rewinding";

          rewindTimer = window.setTimeout(() => {
            rotationStep += delta;
            root.dataset.direction = delta < 0 ? "forward" : "backward";
            root.dataset.phase = "rotating";
            updateStage(targetIndex);
            updateNodes();

            rotationTimer = window.setTimeout(() => {
              playActiveStage(manualSelection);
            }, ROTATION_DURATION);
          }, REWIND_DURATION);
        };

        const pauseNow = () => {
          autoplay = false;
          transitioning = false;
          clearTimers();
          root.dataset.phase = "paused";
          updateStatus();
        };

        const resume = () => {
          if (reduceMotion.matches) return;
          autoplay = true;
          transitioning = false;
          updateStatus();
          playActiveStage(false);
        };

        nodes.forEach((node, index) => {
          node.addEventListener("click", () => transitionTo(index, true), {
            signal: controller.signal,
          });

          node.addEventListener(
            "keydown",
            (event) => {
              if (
                event.key !== "ArrowRight" &&
                event.key !== "ArrowLeft" &&
                event.key !== "Home" &&
                event.key !== "End"
              ) {
                return;
              }

              event.preventDefault();
              const target =
                event.key === "Home"
                  ? 0
                  : event.key === "End"
                    ? nodes.length - 1
                    : modulo(
                        index + (event.key === "ArrowRight" ? 1 : -1),
                        nodes.length,
                      );
              nodes[target]?.focus();
              transitionTo(target, true);
            },
            { signal: controller.signal },
          );
        });

        toggle.addEventListener(
          "click",
          () => {
            if (autoplay) {
              pauseNow();
            } else {
              resume();
            }
          },
          { signal: controller.signal },
        );

        const handleVisibility = () => {
          if (document.hidden) {
            window.clearTimeout(autoplayTimer);
            if (autoplay) root.dataset.phase = "paused";
            return;
          }

          if (autoplay && !reduceMotion.matches) {
            playActiveStage(false);
          }
        };

        const handleMotionPreference = () => {
          clearTimers();
          transitioning = false;
          autoplay = !reduceMotion.matches;
          root.dataset.phase = reduceMotion.matches ? "paused" : "playing";
          updateStatus();
          if (autoplay) scheduleNext();
        };

        document.addEventListener("visibilitychange", handleVisibility, {
          signal: controller.signal,
        });
        reduceMotion.addEventListener("change", handleMotionPreference, {
          signal: controller.signal,
        });

        updateNodes();
        updateStage(0);
        updateStatus();
        if (reduceMotion.matches) root.dataset.phase = "paused";
        scheduleNext();

        orbitCleanups.push(() => {
          clearTimers();
          controller.abort();
        });
      });
  }

  setupTranslationOrbits();
  document.addEventListener("astro:page-load", setupTranslationOrbits);
  document.addEventListener("astro:before-preparation", () => {
    orbitCleanups.forEach((cleanup) => cleanup());
    orbitCleanups = [];
  });
</script>
