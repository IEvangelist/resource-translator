---
import { Icon } from "astro-icon/components";
import Logo from "./Logo.astro";

type StageCopy = {
  short: string;
  title: string;
  body: string;
};

type OrbitCopy = {
  label: string;
  playing: string;
  paused: string;
  reduced: string;
  pause: string;
  resume: string;
  stages: {
    change: StageCopy;
    action: StageCopy;
    provider: StageCopy;
    locales: StageCopy;
    pullRequest: StageCopy;
  };
};

interface Props {
  copy: OrbitCopy;
}

const { copy } = Astro.props;
const stages = [
  {
    id: "change",
    icon: "lucide:file-pen-line",
    ...copy.stages.change,
  },
  {
    id: "action",
    icon: "simple-icons:githubactions",
    ...copy.stages.action,
  },
  {
    id: "provider",
    icon: "lucide:route",
    ...copy.stages.provider,
  },
  {
    id: "locales",
    icon: "lucide:languages",
    ...copy.stages.locales,
  },
  {
    id: "pull-request",
    icon: "lucide:git-pull-request",
    ...copy.stages.pullRequest,
  },
] as const;

const anchorAngle = 144;
const angleStep = 360 / stages.length;
---

<div
  class="translation-orbit"
  data-translation-orbit
  data-phase="playing"
  data-autoplay="running"
  data-reduced="false"
  data-copy-playing={copy.playing}
  data-copy-paused={copy.paused}
  data-copy-reduced={copy.reduced}
  data-copy-pause={copy.pause}
  data-copy-resume={copy.resume}
  dir="ltr"
>
  <div class="orbit-toolbar">
    <span class="orbit-status">
      <i aria-hidden="true"></i>
      <span data-orbit-status>{copy.playing}</span>
    </span>
    <button
      type="button"
      class="orbit-toggle"
      data-orbit-toggle
      aria-label={copy.pause}
    >
      <Icon name="lucide:pause" class="toggle-pause size-3.5" />
      <Icon name="lucide:play" class="toggle-play size-3.5" />
      <span class="sr-only" data-orbit-toggle-label>{copy.pause}</span>
    </button>
  </div>

  <div class="orbit-track" aria-hidden="true"></div>
  <div class="orbit-hub" aria-hidden="true">
    <span class="hub-ring"></span>
    <span class="hub-logo">
      <Logo size={62} />
    </span>
  </div>

  <nav class="orbit-nav" aria-label={copy.label}>
    {
      stages.map((stage, index) => (
        <button
          type="button"
          class="orbit-node"
          data-orbit-node
          data-orbit-index={index}
          data-active={index === 0 ? "true" : "false"}
          data-stage-title={stage.title}
          aria-label={stage.title}
          aria-pressed={index === 0 ? "true" : "false"}
          style={`--orbit-angle: ${anchorAngle + index * angleStep}deg; --node-layer: ${5 - index};`}
        >
          <span class="node-icon" aria-hidden="true">
            <Icon name={stage.icon} class="size-4" />
          </span>
          <span class="node-label">{stage.short}</span>
          <span class="node-progress" aria-hidden="true" />
        </button>
      ))
    }
  </nav>

  <div class="orbit-stage">
    {
      stages.map((stage, index) => (
        <article
          class="stage-card"
          data-orbit-stage
          data-stage-id={stage.id}
          data-active={index === 0 ? "true" : "false"}
          aria-hidden={index === 0 ? "false" : "true"}
        >
          <header class="stage-header">
            <span class="stage-icon" aria-hidden="true">
              <Icon name={stage.icon} class="size-4" />
            </span>
            <div>
              <span class="stage-short">{stage.short}</span>
              <h3>{stage.title}</h3>
            </div>
          </header>
          <p class="stage-body">{stage.body}</p>

          {stage.id === "change" && (
            <div class="event-scene scene-change" aria-hidden="true">
              <div
                class="file-caption sequence-item"
                style="--sequence-delay: 80ms"
              >
                <Icon name="lucide:file-code-2" class="size-3.5" />
                <code>app.en.resx</code>
              </div>
              <div
                class="diff-line diff-old sequence-item"
                style="--sequence-delay: 260ms"
              >
                <span>-</span>
                <code>&lt;value&gt;Ship fast&lt;/value&gt;</code>
              </div>
              <div
                class="diff-line diff-new sequence-item"
                style="--sequence-delay: 520ms"
              >
                <span>+</span>
                <code>&lt;value&gt;Ship with confidence&lt;/value&gt;</code>
              </div>
              <div
                class="scene-result sequence-item"
                style="--sequence-delay: 880ms"
              >
                <Icon name="lucide:sparkles" class="size-3.5" />1 changed key
              </div>
            </div>
          )}

          {stage.id === "action" && (
            <div class="event-scene scene-action" aria-hidden="true">
              <div
                class="runner-head sequence-item"
                style="--sequence-delay: 80ms"
              >
                <Icon name="simple-icons:githubactions" class="size-3.5" />
                <code>translate.yml</code>
                <span>running</span>
              </div>
              <div class="runner-steps">
                {[
                  "Checkout repository",
                  "Detect changed keys",
                  "Build translation plan",
                ].map((label, stepIndex) => (
                  <div
                    class="runner-step sequence-item"
                    style={`--sequence-delay: ${300 + stepIndex * 260}ms`}
                  >
                    <span>
                      <Icon name="lucide:check" class="size-3" />
                    </span>
                    <code>{label}</code>
                  </div>
                ))}
              </div>
              <span
                class="runner-sweep sequence-item"
                style="--sequence-delay: 260ms"
              />
            </div>
          )}

          {stage.id === "provider" && (
            <div class="event-scene scene-provider" aria-hidden="true">
              <div
                class="delegate-source sequence-item"
                style="--sequence-delay: 80ms"
              >
                <Logo size={38} />
                <span>3 keys</span>
              </div>
              <div
                class="delegate-path sequence-item"
                style="--sequence-delay: 360ms"
              >
                <span />
                <i />
              </div>
              <div class="provider-options">
                <span
                  class="provider-option provider-azure sequence-item"
                  style="--sequence-delay: 620ms"
                >
                  <Icon name="simple-icons:microsoftazure" class="size-5" />
                  Azure
                </span>
                <span
                  class="provider-option sequence-item"
                  style="--sequence-delay: 760ms"
                >
                  <Icon name="simple-icons:amazonwebservices" class="size-5" />
                  AWS
                </span>
                <span
                  class="provider-option sequence-item"
                  style="--sequence-delay: 900ms"
                >
                  <Icon name="simple-icons:googlecloud" class="size-5" />
                  Google
                </span>
              </div>
            </div>
          )}

          {stage.id === "locales" && (
            <div class="event-scene scene-locales" aria-hidden="true">
              {[
                ["fr", "Enregistrer"],
                ["de", "Speichern"],
                ["es", "Guardar"],
              ].map(([locale, value], localeIndex) => (
                <div
                  class="locale-result sequence-item"
                  style={`--sequence-delay: ${160 + localeIndex * 260}ms`}
                >
                  <span>{locale}</span>
                  <code>{value}</code>
                  <Icon name="lucide:check" class="size-3.5" />
                </div>
              ))}
            </div>
          )}

          {stage.id === "pull-request" && (
            <div class="event-scene scene-pr" aria-hidden="true">
              <div
                class="pr-heading sequence-item"
                style="--sequence-delay: 100ms"
              >
                <span>
                  <Icon name="lucide:git-pull-request" class="size-4" />
                </span>
                <div>
                  <strong>Update translations</strong>
                  <small>Ready for review</small>
                </div>
                <b>Open</b>
              </div>
              <div class="pr-files">
                {["app.fr.resx", "app.de.resx", "app.es.resx"].map(
                  (file, fileIndex) => (
                    <code
                      class="sequence-item"
                      style={`--sequence-delay: ${380 + fileIndex * 180}ms`}
                    >
                      <Icon name="lucide:file-check-2" class="size-3" />
                      {file}
                    </code>
                  ),
                )}
              </div>
              <div
                class="pr-result sequence-item"
                style="--sequence-delay: 980ms"
              >
                <Icon name="lucide:circle-check" class="size-3.5" />
                Pull request created
              </div>
            </div>
          )}
        </article>
      ))
    }
  </div>

  <span class="sr-only" aria-live="polite" aria-atomic="true" data-orbit-live>
    {stages[0].title}
  </span>
</div>

<style>
  .translation-orbit {
    --orbit-x: 73%;
    --orbit-y: 34%;
    --orbit-radius: 7.7rem;
    --stage-duration: 5.6s;
    position: relative;
    isolation: isolate;
    min-height: 31rem;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 2rem;
    background:
      linear-gradient(rgba(110, 103, 248, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 103, 248, 0.055) 1px, transparent 1px),
      var(--bg-elevated);
    background-size: 2rem 2rem;
    box-shadow: 0 2rem 5rem rgba(70, 53, 188, 0.12);
  }

  .translation-orbit::before {
    position: absolute;
    inset: -25% -20% auto 42%;
    z-index: -1;
    height: 68%;
    content: "";
    border-radius: 50%;
    background: rgba(110, 103, 248, 0.13);
    filter: blur(3.5rem);
    pointer-events: none;
  }

  .orbit-toolbar {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 9;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .orbit-status,
  .orbit-toggle {
    min-height: 2rem;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    box-shadow: 0 0.5rem 1.4rem rgba(70, 53, 188, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .orbit-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.65rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
  }

  .orbit-status i {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-brand-600);
    box-shadow: 0 0 0 0.2rem rgba(110, 103, 248, 0.13);
  }

  .orbit-toggle {
    display: grid;
    place-items: center;
    width: 2rem;
    padding: 0;
    color: var(--fg);
    cursor: pointer;
    transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .orbit-toggle:hover {
    transform: translateY(-1px);
  }

  .orbit-toggle:active {
    transform: translateY(1px) scale(0.96);
  }

  .orbit-toggle:focus-visible,
  .orbit-node:focus-visible {
    outline: 3px solid
      color-mix(in srgb, var(--color-brand-500) 62%, transparent);
    outline-offset: 3px;
  }

  .toggle-play {
    display: none;
  }

  .translation-orbit[data-autoplay="paused"] .toggle-pause {
    display: none;
  }

  .translation-orbit[data-autoplay="paused"] .toggle-play {
    display: block;
  }

  .orbit-track {
    position: absolute;
    left: var(--orbit-x);
    top: var(--orbit-y);
    z-index: 0;
    width: calc(var(--orbit-radius) * 2);
    height: calc(var(--orbit-radius) * 2);
    border: 1px solid
      color-mix(in srgb, var(--color-brand-500) 22%, var(--border));
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .orbit-track::before,
  .orbit-track::after {
    position: absolute;
    inset: 1.1rem;
    content: "";
    border: 1px solid
      color-mix(in srgb, var(--color-brand-500) 12%, transparent);
    border-radius: inherit;
  }

  .orbit-track::after {
    inset: 2.2rem;
  }

  .orbit-hub {
    position: absolute;
    left: var(--orbit-x);
    top: var(--orbit-y);
    z-index: 4;
    display: grid;
    place-items: center;
    width: 5.4rem;
    height: 5.4rem;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hub-ring {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(110, 103, 248, 0.36);
    border-radius: 1.6rem;
  }

  .hub-ring::before,
  .hub-ring::after {
    position: absolute;
    width: 0.55rem;
    height: 0.55rem;
    content: "";
    border: 2px solid var(--color-brand-500);
    border-radius: 50%;
    background: var(--bg-elevated);
  }

  .hub-ring::before {
    top: -0.3rem;
    left: 1rem;
  }

  .hub-ring::after {
    right: 0.65rem;
    bottom: -0.3rem;
  }

  .hub-logo {
    display: grid;
    place-items: center;
    width: 4.1rem;
    height: 4.1rem;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    background: var(--bg);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      0 1rem 2.25rem rgba(70, 53, 188, 0.17);
  }

  .orbit-nav {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
  }

  .orbit-node {
    --node-scale: 0.88;
    position: absolute;
    left: var(--orbit-x);
    top: var(--orbit-y);
    z-index: var(--node-layer);
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    align-items: center;
    gap: 0.55rem;
    width: 7.4rem;
    min-height: 3.2rem;
    margin: -1.6rem 0 0 -3.7rem;
    padding: 0.45rem 0.55rem;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 0.95rem;
    color: var(--fg);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    box-shadow: 0 0.75rem 1.8rem rgba(70, 53, 188, 0.1);
    transform: rotate(var(--orbit-angle)) translateX(var(--orbit-radius))
      rotate(calc(-1 * var(--orbit-angle))) scale(var(--node-scale));
    cursor: pointer;
    pointer-events: auto;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    translate: 0 0;
    transition:
      transform 780ms cubic-bezier(0.22, 1, 0.36, 1),
      translate 780ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 280ms ease;
  }

  .orbit-node:hover {
    --node-scale: 0.94;
  }

  .orbit-node:active {
    --node-scale: 0.84;
  }

  .orbit-node[data-active="true"] {
    --node-scale: 1.08;
    border-color: color-mix(
      in srgb,
      var(--scene-accent, var(--color-brand-500)) 52%,
      var(--border)
    );
    background: var(--bg);
    box-shadow: 0 1rem 2.4rem rgba(70, 53, 188, 0.17);
  }

  .orbit-node[data-orbit-index="0"],
  .stage-card[data-stage-id="change"] {
    --scene-accent: #db2777;
  }

  .orbit-node[data-orbit-index="1"],
  .stage-card[data-stage-id="action"] {
    --scene-accent: #0969da;
  }

  .orbit-node[data-orbit-index="2"],
  .stage-card[data-stage-id="provider"] {
    --scene-accent: #6e67f8;
  }

  .orbit-node[data-orbit-index="3"],
  .stage-card[data-stage-id="locales"] {
    --scene-accent: #0284c7;
  }

  .orbit-node[data-orbit-index="4"],
  .stage-card[data-stage-id="pull-request"] {
    --scene-accent: #15803d;
  }

  :global(.dark) .orbit-node[data-orbit-index="0"],
  :global(.dark) .stage-card[data-stage-id="change"] {
    --scene-accent: #f472b6;
  }

  :global(.dark) .orbit-node[data-orbit-index="1"],
  :global(.dark) .stage-card[data-stage-id="action"] {
    --scene-accent: #60a5fa;
  }

  :global(.dark) .orbit-node[data-orbit-index="2"],
  :global(.dark) .stage-card[data-stage-id="provider"] {
    --scene-accent: var(--color-brand-200);
  }

  :global(.dark) .orbit-node[data-orbit-index="3"],
  :global(.dark) .stage-card[data-stage-id="locales"] {
    --scene-accent: #38bdf8;
  }

  :global(.dark) .orbit-node[data-orbit-index="4"],
  :global(.dark) .stage-card[data-stage-id="pull-request"] {
    --scene-accent: #4ade80;
  }

  .node-icon,
  .stage-icon {
    display: grid;
    place-items: center;
    color: var(--scene-accent, var(--color-brand-700));
    background: color-mix(
      in srgb,
      var(--scene-accent, var(--color-brand-700)) 12%,
      var(--bg)
    );
  }

  :global(.dark) .node-icon,
  :global(.dark) .stage-icon {
    color: var(--scene-accent, var(--color-brand-200));
    background: color-mix(
      in srgb,
      var(--scene-accent, var(--color-brand-200)) 18%,
      var(--bg)
    );
  }

  .node-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.65rem;
  }

  .node-label {
    overflow: hidden;
    font-size: 0.68rem;
    font-weight: 750;
    line-height: 1.15;
    text-align: left;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .node-progress {
    position: absolute;
    inset: auto 0 0;
    height: 2px;
    background: var(--scene-accent, var(--color-brand-600));
    transform: scaleX(0);
    transform-origin: left;
  }

  .orbit-stage {
    position: absolute;
    inset: auto 4.75rem 1rem 1rem;
    z-index: 3;
    height: 17.3rem;
  }

  .stage-card {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: auto auto minmax(0, 1fr);
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 1.35rem;
    background: var(--bg);
    box-shadow: 0 1.5rem 3rem rgba(70, 53, 188, 0.12);
    opacity: 0;
    transform: translate3d(0, 0.85rem, 0) scale(0.985);
    pointer-events: none;
    transition:
      transform 520ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 280ms ease;
  }

  .stage-card[data-active="true"] {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    pointer-events: auto;
  }

  .translation-orbit[data-phase="rewinding"] .stage-card[data-active="true"] {
    opacity: 0;
    transform: translate3d(0.75rem, -0.5rem, 0) scale(0.97);
  }

  .translation-orbit[data-phase="rotating"] .stage-card,
  .translation-orbit[data-phase="reset"] .stage-card {
    opacity: 0;
    transform: translate3d(-0.65rem, 0.65rem, 0) scale(0.985);
  }

  .translation-orbit[data-phase="paused"]
    .stage-card[data-active="true"]
    .sequence-item {
    opacity: 1;
    transform: none;
  }

  .translation-orbit[data-phase="paused"]
    .stage-card[data-stage-id="action"][data-active="true"]
    .runner-sweep {
    opacity: 1;
    transform: scaleY(1);
  }

  .translation-orbit[data-phase="paused"]
    .stage-card[data-stage-id="provider"][data-active="true"]
    .delegate-path
    span {
    opacity: 1;
    transform: translate3d(180%, 0, 0) scaleX(0.35);
  }

  .stage-header {
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr);
    align-items: center;
    gap: 0.7rem;
    max-width: calc(100% - 7.5rem);
  }

  .stage-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.7rem;
  }

  .stage-short {
    display: block;
    margin-bottom: 0.15rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 0.59rem;
    font-weight: 700;
  }

  .stage-card h3 {
    margin: 0;
    font-size: clamp(0.98rem, 1.7vw, 1.2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  .stage-body {
    max-width: 42ch;
    margin: 0.6rem 0 0;
    color: var(--fg-muted);
    font-size: 0.76rem;
    line-height: 1.55;
  }

  .event-scene {
    position: relative;
    align-self: end;
    min-height: 7.3rem;
    margin-top: 0.8rem;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--bg-elevated);
  }

  .sequence-item {
    opacity: 0;
    transform: translate3d(0, 0.7rem, 0);
  }

  .file-caption,
  .runner-head {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.25rem;
    padding: 0.45rem 0.7rem;
    border-bottom: 1px solid var(--border);
    color: var(--fg-muted);
    font-size: 0.61rem;
  }

  .file-caption code,
  .runner-head code {
    overflow: hidden;
    color: var(--fg);
    font-size: 0.63rem;
    font-weight: 700;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .file-caption span,
  .runner-head span {
    color: var(--link);
    font-family: var(--font-mono);
    font-size: 0.56rem;
    font-weight: 750;
  }

  .diff-line {
    display: grid;
    grid-template-columns: 1.2rem minmax(0, 1fr);
    align-items: center;
    gap: 0.35rem;
    min-height: 1.8rem;
    padding-inline: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.59rem;
  }

  .diff-line span {
    font-weight: 800;
  }

  .diff-line code {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .diff-old {
    color: color-mix(in srgb, #be123c 76%, var(--fg));
    background: color-mix(in srgb, #e11d48 7%, var(--bg-elevated));
  }

  .diff-new {
    color: color-mix(in srgb, #15803d 84%, var(--fg));
    background: color-mix(in srgb, #22c55e 10%, var(--bg-elevated));
  }

  :global(.dark) .diff-old {
    color: #fda4af;
    background: color-mix(in srgb, #e11d48 13%, var(--bg-elevated));
  }

  :global(.dark) .diff-new {
    color: #86efac;
