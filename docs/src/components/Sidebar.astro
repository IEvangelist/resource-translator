---
import { Icon } from "astro-icon/components";
import NavLink from "./NavLink.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const normalize = (href: string) =>
  (base + href).replace(/\/$/, "") || "/";

const sections = [
  {
    title: "Start here",
    icon: "lucide:rocket",
    items: [
      { href: "/", label: "Overview", icon: "lucide:sparkles" },
      { href: "/getting-started", label: "Getting started", icon: "lucide:zap" },
      { href: "/configuration", label: "Configuration", icon: "lucide:settings-2" },
    ],
  },
  {
    title: "Reference",
    icon: "lucide:code-2",
    items: [
      { href: "/inputs", label: "Inputs & outputs", icon: "lucide:file-text" },
      { href: "/formats", label: "File formats", icon: "lucide:package" },
      { href: "/recipes", label: "Recipes", icon: "lucide:wand-sparkles" },
      { href: "/faq", label: "FAQ", icon: "lucide:circle-dashed" },
    ],
  },
  {
    title: "Project",
    icon: "lucide:git-pull-request",
    items: [
      { href: "/contributing", label: "Contributing", icon: "lucide:git-pull-request" },
      { href: "/changelog", label: "Changelog", icon: "lucide:check" },
    ],
  },
];
---

<nav aria-label="Documentation" class="space-y-7">
  {
    sections.map((section) => (
      <div>
        <p class="flex items-center gap-2 px-3 text-xs font-semibold uppercase tracking-wider text-(--fg-muted)">
          <Icon name={section.icon} class="size-3.5" />
          {section.title}
        </p>
        <ul class="mt-2 space-y-0.5">
          {section.items.map((item) => {
            const target = normalize(item.href);
            const current = pathname === target;
            return (
              <li>
                <NavLink
                  href={target}
                  label={item.label}
                  icon={item.icon}
                  current={current}
                />
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</nav>

