---
import { Icon } from "astro-icon/components";
import NavLink from "./NavLink.astro";
import type { NavMessages } from "../i18n/messages";
import { defaultLocale } from "../i18n/locales";
import {
  localizedHref,
  navSections,
  slugFromPath,
  type PageSlug,
} from "../i18n/routes";

interface Props {
  locale?: string;
  nav?: NavMessages;
  currentSlug?: PageSlug;
}

const {
  locale = defaultLocale,
  nav,
  currentSlug = slugFromPath(Astro.url.pathname),
} = Astro.props;
---

<nav aria-label="Documentation" class="space-y-3">
  {
    navSections.map((section) => (
      <details
        open
        data-sidebar-section={section.key}
        class="group rounded-lg border border-transparent transition-colors open:bg-(--bg-elevated)"
      >
        <summary class="flex select-none items-center gap-2 rounded-lg px-3 py-2 text-sm font-semibold tracking-wide text-(--fg) transition-colors hover:bg-(--bg-elevated)">
          <Icon
            name={section.icon}
            class="size-4 flex-none text-(--color-accent-700) dark:text-(--color-accent-300)"
          />
          <span class="flex-1">{nav?.sections[section.key] ?? section.key}</span>
          <Icon
            name="lucide:chevron-right"
            data-chevron
            aria-hidden="true"
            class="size-4 flex-none text-(--fg-muted)"
          />
        </summary>
        <ul class="mt-1 mb-2 space-y-0.5 px-1.5">
          {section.items.map((item) => {
            const target = localizedHref(locale, item.slug);
            const current = currentSlug === item.slug;
            return (
              <li>
                <NavLink
                  href={target}
                  label={nav?.items[item.key] ?? item.key}
                  icon={item.icon}
                  current={current}
                />
              </li>
            );
          })}
        </ul>
      </details>
    ))
  }
</nav>

<script>
  // Persist collapsible state across navigations and sessions.
  function bindSidebarSections() {
    document
      .querySelectorAll<HTMLDetailsElement>("details[data-sidebar-section]")
      .forEach((d) => {
        const key = `rt:sb:${d.dataset.sidebarSection}`;
        try {
          const stored = localStorage.getItem(key);
          if (stored === "closed") d.removeAttribute("open");
          else if (stored === "open") d.setAttribute("open", "");
        } catch {
          /* localStorage may be unavailable (private mode, file://, etc.) */
        }
        if (d.dataset.bound === "1") return;
        d.dataset.bound = "1";
        d.addEventListener("toggle", () => {
          try {
            localStorage.setItem(key, d.open ? "open" : "closed");
          } catch {
            /* ignore */
          }
        });
      });
  }
  bindSidebarSections();
  document.addEventListener("astro:page-load", bindSidebarSections);
</script>

