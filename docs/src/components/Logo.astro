---
interface Props {
  size?: number;
  class?: string;
}

const { size = 28, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  class={className}
  aria-hidden="true"
>
  <defs>
    <linearGradient id="rt-grad-a" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#6e67f8" />
      <stop offset="55%" stop-color="#d71cd0" />
      <stop offset="100%" stop-color="#ea8b00" />
    </linearGradient>
    <linearGradient id="rt-grad-b" x1="0" y1="64" x2="64" y2="0" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#ea8b00" />
      <stop offset="100%" stop-color="#6e67f8" />
    </linearGradient>
  </defs>
  <rect x="2" y="2" width="60" height="60" rx="14" fill="url(#rt-grad-a)" />
  <circle
    cx="32"
    cy="32"
    r="20"
    stroke="white"
    stroke-opacity="0.35"
    stroke-width="1.25"
    fill="none"
  />
  <ellipse
    cx="32"
    cy="32"
    rx="20"
    ry="9"
    stroke="white"
    stroke-opacity="0.35"
    stroke-width="1.25"
    fill="none"
  />
  <path
    d="M12 32 H52 M32 12 V52"
    stroke="white"
    stroke-opacity="0.18"
    stroke-width="1"
  />
  {/* Stylized "A" glyph rendered as paths so axe color-contrast rules
      treat the SVG as a pure decorative graphic instead of low-contrast
      text. The literal text glyphs failed AA against the gradient stops. */}
  <path
    d="M14 41 L20 23 L26 41 M16.4 35 L23.6 35"
    fill="none"
    stroke="white"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <path
    d="M27 30 L37 30 M34 27 L37 30 L34 33"
    stroke="white"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  {/* Stylized "文" — top dot + horizontal hat, then crossing diagonals. */}
  <path
    d="M44 24 L44 25.5 M40 27 L48 27 M39 31 L49 31 M40 41 L44 33 L48 41"
    fill="none"
    stroke="white"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
