---
import { Icon } from "astro-icon/components";
import Logo from "./Logo.astro";
import type { CommonMessages, NavMessages } from "../i18n/messages";
import { defaultLocale } from "../i18n/locales";
import { allLocales } from "../i18n/locales";
import { localizedHref } from "../i18n/routes";
import type { PageSlug } from "../i18n/routes";
import { getStarCount } from "../data/github";

const year = new Date().getFullYear();

interface Props {
  locale?: string;
  common?: CommonMessages;
  nav?: NavMessages;
  slug?: PageSlug;
}

const { locale = defaultLocale, common, nav, slug = "index" } = Astro.props;

const repoUrl = "https://github.com/IEvangelist/resource-translator";
const marketplaceUrl =
  "https://github.com/marketplace/actions/resource-translator";
const npmUrl = "https://www.npmjs.com/package/@azure-rest/ai-translation-text";

// Keep in lock-step with the `uses:` references across the docs pages.
const actionVersion = "v3";
const installSnippet = `- uses: IEvangelist/resource-translator@${actionVersion}`;
const changelogHref = localizedHref(locale, "changelog");
// Per-page GitHub links: the layout source lives next to the slug; index maps
// to index.astro. Report-an-issue prefills the title so triage knows the page.
const editUrl = `${repoUrl}/blob/main/docs/src/pages/${slug}.astro`;
const reportIssueUrl = `${repoUrl}/issues/new?labels=documentation&title=${encodeURIComponent(
  `Docs: issue on the "${slug}" page`,
)}`;

const stars = await getStarCount();

const docsLinks: { href: string; label: string }[] = [
  { href: localizedHref(locale, "index"), label: nav?.items.overview ?? "Overview" },
  {
    href: localizedHref(locale, "getting-started"),
    label: nav?.items.gettingStarted ?? "Getting started",
  },
  {
    href: localizedHref(locale, "configuration"),
    label: nav?.items.configuration ?? "Configuration",
  },
  { href: localizedHref(locale, "inputs"), label: nav?.items.inputs ?? "Inputs & outputs" },
  { href: localizedHref(locale, "formats"), label: nav?.items.formats ?? "File formats" },
  { href: localizedHref(locale, "faq"), label: nav?.items.faq ?? "FAQ" },
];

const projectLinks: { href: string; label: string }[] = [
  { href: localizedHref(locale, "recipes"), label: nav?.items.recipes ?? "Recipes" },
  {
    href: localizedHref(locale, "translations"),
    label: nav?.items.translations ?? "Translations",
  },
  {
    href: localizedHref(locale, "contributing"),
    label: nav?.items.contributing ?? "Contributing",
  },
  { href: localizedHref(locale, "changelog"), label: nav?.items.changelog ?? "Changelog" },
];

const communityLinks: { href: string; label: string }[] = [
  {
    href: `${repoUrl}/issues/new?template=bug_report.yml`,
    label: nav?.community.reportBug ?? "Report a bug",
  },
  {
    href: `${repoUrl}/issues/new?template=feature_request.yml`,
    label: nav?.community.requestFeature ?? "Request a feature",
  },
  { href: `${repoUrl}/discussions`, label: nav?.community.discussions ?? "Discussions" },
  {
    href: `${repoUrl}/blob/main/SECURITY.md`,
    label: nav?.community.securityPolicy ?? "Security policy",
  },
  {
    href: `${repoUrl}/blob/main/CODE_OF_CONDUCT.md`,
    label: nav?.community.codeOfConduct ?? "Code of conduct",
  },
  { href: `${repoUrl}/blob/main/LICENSE`, label: nav?.community.license ?? "MIT License" },
];

const isExternal = (href: string) => /^https?:\/\//.test(href);
const footer = common?.footer;
const site = common?.site;
const currentLocale = allLocales.find((item) => item.code === locale);
const localeLabel = currentLocale?.nativeName ?? locale;
---

<footer
  class="relative mt-16 border-t border-(--border) bg-(--bg-elevated) text-sm text-(--fg-muted)"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-(--color-brand-500)/40 to-transparent"
  >
  </div>

  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-12">
      <!-- Brand + tagline + quick install + socials -->
      <div class="lg:col-span-4 min-w-0">
        <a
          href={localizedHref(locale, "index")}
          class="group inline-flex items-center gap-2.5 text-base font-semibold text-(--fg) no-underline"
        >
          <Logo
            size={32}
            class="rounded-lg shadow-sm transition-transform group-hover:rotate-[-6deg]"
          />
          <span>{site?.name ?? "Resource Translator"}</span>
        </a>
        <p class="mt-4 max-w-sm leading-relaxed">
          {footer?.taglinePrefix ??
            "A GitHub Action that translates your resource files automatically, built atop the official"}
          <a
            href={npmUrl}
            rel="noopener"
            target="_blank"
            class="rt-foot-prose-link">@azure-rest/ai-translation-text</a
          > {footer?.taglineMiddle ?? "SDK from"} <a
            href="https://github.com/Azure/azure-sdk-for-js"
            rel="noopener"
            target="_blank"
            class="rt-foot-prose-link">Azure SDK for JavaScript</a
          >.
        </p>

        <!-- Quick-install snippet with copy button -->
        <div class="mt-6 min-w-0">
          <p
            id="rt-foot-install-label"
            class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-(--fg)"
          >
            {footer?.installLabel ?? "Add it to your workflow"}
          </p>
          <div class="rt-foot-snippet" role="group" aria-labelledby="rt-foot-install-label">
            <code class="rt-foot-snippet-code" data-snippet>{installSnippet}</code>
            <button
              type="button"
              class="rt-foot-copy"
              data-copy-snippet
              data-copy-label={footer?.copy ?? "Copy"}
              data-copied-label={footer?.copied ?? "Copied!"}
              aria-label={footer?.copyAria ?? "Copy the install snippet to your clipboard"}
            >
              <Icon name="lucide:copy" class="size-3.5" data-copy-icon aria-hidden="true" />
              <Icon
                name="lucide:check"
                class="size-3.5 hidden text-(--color-brand-500)"
                data-check-icon
                aria-hidden="true"
              />
              <span data-copy-text>{footer?.copy ?? "Copy"}</span>
            </button>
          </div>
        </div>

        <!-- Primary CTAs: Marketplace + star -->
        <div class="mt-5 flex flex-wrap items-center gap-2.5">
          <a
            href={marketplaceUrl}
            rel="noopener"
            target="_blank"
            class="rt-foot-cta rt-foot-cta-primary"
          >
            <Icon name="simple-icons:githubactions" class="size-4" aria-hidden="true" />
            <span>{footer?.marketplaceCta ?? "Get it on GitHub Marketplace"}</span>
          </a>
          <a
            href={`${repoUrl}/stargazers`}
            rel="noopener"
            target="_blank"
            class="rt-foot-cta"
            aria-label={footer?.starAria ?? "Star Resource Translator on GitHub"}
          >
            <Icon name="lucide:star" class="size-4" aria-hidden="true" />
            <span>{footer?.starCta ?? "Star on GitHub"}</span>
            {stars && (
              <span
                class="rt-foot-star-count"
                aria-label={footer?.stargazersAria ?? "GitHub stargazers count"}
              >
                {stars}
              </span>
            )}
          </a>
        </div>

        <!-- Socials + version + language -->
        <div class="mt-6 flex flex-wrap items-center gap-2">
          <ul
            class="flex items-center gap-2"
            aria-label={footer?.projectLinksAria ?? "Project links"}
          >
            <li>
              <a
                href={repoUrl}
                rel="noopener"
                target="_blank"
                aria-label={footer?.sourceAria ?? "View source on GitHub"}
                title="GitHub repository"
                class="rt-social"
              >
                <Icon name="simple-icons:github" class="size-4" />
              </a>
            </li>
            <li>
              <a
                href={npmUrl}
                rel="noopener"
                target="_blank"
                aria-label={footer?.npmAria ?? "View the Azure Translator SDK on npm"}
                title="npm"
                class="rt-social"
              >
                <Icon name="simple-icons:npm" class="size-4" />
              </a>
            </li>
            <li>
              <a
                href="https://davidpine.dev"
                rel="noopener"
                target="_blank"
                aria-label={footer?.authorAria ?? "David Pine's website"}
                title="davidpine.dev"
                class="rt-social"
              >
                <Icon name="lucide:globe" class="size-4" />
              </a>
            </li>
          </ul>

          <a
            href={changelogHref}
            class="rt-foot-pill"
            title={footer?.whatsNew ?? "What's new"}
          >
            <Icon name="lucide:tag" class="size-3.5" aria-hidden="true" />
            <span class="font-mono" dir="ltr">{actionVersion}</span>
            <span class="text-(--fg-muted)">·</span>
            <span>{footer?.whatsNew ?? "What's new"}</span>
          </a>

          <button
            type="button"
            data-language-trigger
            class="rt-foot-pill"
            aria-label={footer?.language ?? "Language"}
            aria-haspopup="dialog"
            aria-controls="language-dialog"
          >
            <Icon name="lucide:languages" class="size-3.5" aria-hidden="true" />
            <span class="max-w-32 truncate">{localeLabel}</span>
            <span class="font-mono uppercase text-(--fg-muted)" dir="ltr">{locale}</span>
          </button>
        </div>
      </div>

      <!-- Footer · Docs (sidebar already owns the primary "Documentation"
           landmark; rename here to keep landmarks unique per axe). -->
      <nav class="lg:col-span-2" aria-label="Footer · Docs">
        <h2
          class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-(--fg)"
        >
          {footer?.docs ?? "Docs"}
        </h2>
        <ul class="space-y-2">
          {
            docsLinks.map((l) => (
              <li>
                <a class="rt-foot-link" href={l.href}>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Project -->
      <nav class="lg:col-span-2" aria-label="Footer · Project">
        <h2
          class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-(--fg)"
        >
          {footer?.project ?? "Project"}
        </h2>
        <ul class="space-y-2">
          {
            projectLinks.map((l) => (
              <li>
                <a class="rt-foot-link" href={l.href}>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Community -->
      <nav class="lg:col-span-4" aria-label="Footer · Community and support">
        <h2
          class="mb-4 text-xs font-semibold uppercase tracking-[0.14em] text-(--fg)"
        >
          {footer?.community ?? "Community"}
        </h2>
        <ul class="grid gap-2 sm:grid-cols-2">
          {
            communityLinks.map((l) => (
              <li>
                <a
                  class="rt-foot-link inline-flex items-center gap-1.5"
                  href={l.href}
                  rel={isExternal(l.href) ? "noopener" : undefined}
                  target={isExternal(l.href) ? "_blank" : undefined}
                >
                  <span>{l.label}</span>
                  {isExternal(l.href) && (
                    <Icon
                      name="lucide:external-link"
                      class="size-3 opacity-50"
                      aria-hidden="true"
                    />
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Per-page contribution links (contextual to the current doc) -->
    <div
      class="mt-10 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-(--border) pt-6 text-xs"
    >
      <a
        href={editUrl}
        rel="noopener"
        target="_blank"
        class="rt-foot-page-link"
        aria-label={footer?.editPageAria ?? "Edit this page's source on GitHub"}
      >
        <Icon name="lucide:pencil" class="size-3.5" aria-hidden="true" />
        <span>{footer?.editPage ?? "Edit this page"}</span>
      </a>
      <a
        href={reportIssueUrl}
        rel="noopener"
        target="_blank"
        class="rt-foot-page-link"
      >
        <Icon name="lucide:flag" class="size-3.5" aria-hidden="true" />
        <span>{footer?.reportIssue ?? "Report an issue with this page"}</span>
      </a>
    </div>

    <div
      class="mt-6 flex flex-col items-center justify-between gap-3 text-xs sm:flex-row"
    >
      <p>
        © {year}
        <a
          href="https://davidpine.dev"
          rel="noopener"
          target="_blank"
          class="rt-foot-prose-link font-medium">David Pine 🤓</a
        >
        · {footer?.copyrightPrefix ?? "Released under the"}
        <a
          href={`${repoUrl}/blob/main/LICENSE`}
          rel="noopener"
          target="_blank"
          class="rt-foot-prose-link">MIT License</a
        >.
      </p>
      <p>
        {footer?.builtWith ?? "Built with"}
        <a href="https://astro.build" rel="noopener" target="_blank" class="rt-foot-prose-link">Astro</a>
        &
        <a href="https://tailwindcss.com" rel="noopener" target="_blank" class="rt-foot-prose-link"
          >Tailwind CSS</a
        >.
      </p>
    </div>
  </div>
</footer>

<style>
  /* Footer chrome links: every prose-ish inline `<a>` in the footer
     resolves to `--fg` instead of `--link` so it stays at body-text
     contrast (>= 17:1 in dark, >= 14:1 in light) regardless of how a
     contrast tool resolves nested var() chains. The underline (already
     applied via the global `:where(p, li, ...) a` rule) carries the
     link affordance. Hover lights up with the accent color so they
     still feel interactive. */
  .rt-foot-prose-link {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 150ms ease;
  }
  .rt-foot-prose-link:hover {
    color: var(--link-hover);
    text-decoration-thickness: 2px;
  }

  .rt-foot-link {
    color: var(--fg-muted);
    text-decoration: none;
    transition:
      color 150ms ease,
      transform 150ms ease;
  }
  .rt-foot-link:hover {
    color: var(--fg);
    transform: translateX(2px);
  }
  .rt-foot-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .rt-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--fg-muted);
    text-decoration: none;
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background 150ms ease,
      transform 150ms ease;
  }
  .rt-social:hover {
    color: var(--fg);
    border-color: var(--color-brand-500);
    background: var(--bg);
    transform: translateY(-1px);
  }
  .rt-social:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* Quick-install snippet + copy button */
  .rt-foot-snippet {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--bg);
    padding: 0.25rem 0.25rem 0.25rem 0.625rem;
  }
  .rt-foot-snippet-code {
    flex: 1 1 auto;
    min-width: 0;
    align-self: center;
    overflow-x: auto;
    white-space: nowrap;
    font-size: 0.75rem;
    color: var(--fg);
    background: transparent;
    border: 0;
    padding: 0;
  }
  .rt-foot-copy {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background: var(--bg-elevated);
    color: var(--fg-muted);
    padding: 0.3125rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background 150ms ease;
  }
  .rt-foot-copy:hover {
    color: var(--fg);
    border-color: var(--color-brand-500);
  }
  .rt-foot-copy:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* Primary + secondary CTAs (Marketplace, star) */
  .rt-foot-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    color: var(--fg);
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background 150ms ease,
      transform 150ms ease;
  }
  .rt-foot-cta:hover {
    border-color: var(--color-brand-500);
    transform: translateY(-1px);
  }
  .rt-foot-cta:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .rt-foot-cta-primary {
    border-color: transparent;
    background: var(--color-brand-600);
    color: #fff;
  }
  .rt-foot-cta-primary:hover {
    background: var(--color-brand-500);
    border-color: transparent;
  }
  .rt-foot-star-count {
    border-radius: 999px;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0 0.4375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    line-height: 1.35rem;
    font-variant-numeric: tabular-nums;
  }

  /* Version + language pills */
  .rt-foot-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-elevated);
    color: var(--fg-muted);
    padding: 0.3125rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition:
      color 150ms ease,
      border-color 150ms ease,
      background 150ms ease;
  }
  .rt-foot-pill:hover {
    color: var(--fg);
    border-color: var(--color-brand-500);
    background: var(--bg);
  }
  .rt-foot-pill:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* Contextual edit / report links */
  .rt-foot-page-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .rt-foot-page-link:hover {
    color: var(--fg);
  }
  .rt-foot-page-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>

<script>
  // Copy-to-clipboard for the footer install snippet. Re-binds across view
  // transitions (ClientRouter swaps the DOM) and reverts the button label
  // back to its idle state after a short confirmation window.
  function bindFooterCopy() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(
      "[data-copy-snippet]",
    );
    buttons.forEach((button) => {
      if (button.dataset.bound === "1") return;
      button.dataset.bound = "1";

      const snippet = button
        .closest(".rt-foot-snippet")
        ?.querySelector<HTMLElement>("[data-snippet]");
      const label = button.querySelector<HTMLElement>("[data-copy-text]");
      const copyIcon = button.querySelector<HTMLElement>("[data-copy-icon]");
      const checkIcon = button.querySelector<HTMLElement>("[data-check-icon]");
      const copyText = button.dataset.copyLabel ?? "Copy";
      const copiedText = button.dataset.copiedLabel ?? "Copied!";
      let timer: number | undefined;

      button.addEventListener("click", async () => {
        const text = snippet?.textContent?.trim();
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          // Fallback for insecure contexts / older browsers.
          const area = document.createElement("textarea");
          area.value = text;
          area.setAttribute("readonly", "");
          area.style.position = "absolute";
          area.style.left = "-9999px";
          document.body.appendChild(area);
          area.select();
          try {
            document.execCommand("copy");
          } finally {
            document.body.removeChild(area);
          }
        }

        if (label) label.textContent = copiedText;
        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          if (label) label.textContent = copyText;
          copyIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
        }, 2000);
      });
    });
  }
  bindFooterCopy();
  document.addEventListener("astro:page-load", bindFooterCopy);
</script>
