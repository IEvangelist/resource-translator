---
import { Icon } from "astro-icon/components";

const { href, label, icon, current } = Astro.props as {
  href: string;
  label: string;
  icon?: string;
  current?: boolean;
};
---

<a
  href={href}
  class:list={[
    "group relative flex items-center gap-2 rounded-md px-3 py-1.5 text-sm transition-colors",
    "before:pointer-events-none before:absolute before:inset-y-1 before:left-0 before:w-[3px] before:rounded-r-full before:transition-colors",
    current
      ? "bg-(--color-brand-50) font-semibold text-(--color-brand-700) before:bg-(--color-brand-500) dark:bg-(--color-brand-900)/40 dark:text-(--color-brand-200) dark:before:bg-(--color-brand-400)"
      : "text-(--fg-muted) before:bg-transparent hover:bg-(--bg-elevated) hover:text-(--fg)",
  ]}
  aria-current={current ? "page" : undefined}
>
  {
    icon ? (
      <Icon
        name={icon}
        class:list={[
          "size-3.5 flex-none transition-colors",
          current ? "text-(--color-accent-500)" : "opacity-70 group-hover:opacity-100",
        ]}
      />
    ) : null
  }
  <span>{label}</span>
</a>

