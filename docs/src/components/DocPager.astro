---
import { Icon } from "astro-icon/components";
import type { CommonMessages, NavMessages } from "../i18n/messages";
import { defaultLocale } from "../i18n/locales";
import {
  flatNavItems,
  localizedHref,
  slugFromPath,
  type PageSlug,
} from "../i18n/routes";

interface Props {
  locale?: string;
  nav?: NavMessages;
  pager?: CommonMessages["pager"];
  currentSlug?: PageSlug;
}

const {
  locale = defaultLocale,
  nav,
  pager,
  currentSlug = slugFromPath(Astro.url.pathname),
} = Astro.props;

const index = flatNavItems.findIndex((item) => item.slug === currentSlug);
const prev = index > 0 ? flatNavItems[index - 1] : null;
const next =
  index >= 0 && index < flatNavItems.length - 1 ? flatNavItems[index + 1] : null;
const hasPager = index >= 0 && (prev || next);
---

{
  hasPager && (
      <nav
      aria-label={pager?.ariaLabel ?? "Article"}
      class="not-prose mt-16 grid max-w-3xl gap-3 border-t border-(--border) pt-8 sm:grid-cols-2"
    >
      {prev ? (
        <a
          href={localizedHref(locale, prev.slug)}
          rel="prev"
          class="group flex flex-col gap-1 rounded-xl border border-(--border) bg-(--bg-elevated) px-4 py-3 transition-colors hover:border-(--color-brand-400) hover:bg-(--bg) sm:col-start-1"
        >
          <span class="inline-flex items-center gap-1.5 text-xs font-medium tracking-wide text-(--fg-muted) uppercase">
            <Icon name="lucide:arrow-left" class="size-3.5" />
            {pager?.previous ?? "Previous"}
          </span>
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-(--fg) group-hover:text-(--link)">
            {prev.icon ? (
              <Icon
                name={prev.icon}
                class="size-4 flex-none text-(--color-accent-500)"
              />
            ) : null}
            {nav?.items[prev.key] ?? prev.key}
          </span>
        </a>
      ) : (
        <span class="hidden sm:block" aria-hidden="true" />
      )}

      {next ? (
        <a
          href={localizedHref(locale, next.slug)}
          rel="next"
          class="group flex flex-col gap-1 rounded-xl border border-(--border) bg-(--bg-elevated) px-4 py-3 text-right transition-colors hover:border-(--color-brand-400) hover:bg-(--bg) sm:col-start-2"
        >
          <span class="inline-flex items-center justify-end gap-1.5 text-xs font-medium tracking-wide text-(--fg-muted) uppercase">
            {pager?.next ?? "Next"}
            <Icon name="lucide:arrow-right" class="size-3.5" />
          </span>
          <span class="inline-flex items-center justify-end gap-2 text-sm font-semibold text-(--fg) group-hover:text-(--link)">
            {nav?.items[next.key] ?? next.key}
            {next.icon ? (
              <Icon
                name={next.icon}
                class="size-4 flex-none text-(--color-accent-500)"
              />
            ) : null}
          </span>
        </a>
      ) : null}
    </nav>
  )
}
