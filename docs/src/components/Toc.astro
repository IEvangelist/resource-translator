---
interface Props {
  title?: string;
}

const { title = "On this page" } = Astro.props;
---

<aside
  aria-label={title}
  class="hidden flex-none xl:block xl:w-56"
>
  <div class="sticky top-24" data-toc-root>
    <p
      class="mb-3 px-3 text-xs font-semibold uppercase tracking-[0.14em] text-(--fg-muted)"
    >
      {title}
    </p>
    <ul id="toc-list" class="border-l border-(--border)"></ul>
  </div>
</aside>

<style is:global>
  .rt-toc-link {
    display: block;
    margin-left: -1px;
    padding: 0.3rem 0.75rem;
    border-left: 2px solid transparent;
    color: var(--fg-muted);
    font-size: 0.85rem;
    line-height: 1.35;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .rt-toc-link:hover {
    color: var(--fg);
    border-color: var(--border);
  }
  .rt-toc-link[data-toc-level="3"] {
    padding-left: 1.5rem;
    font-size: 0.8rem;
  }
  .rt-toc-link[data-active="true"] {
    color: var(--link);
    border-color: var(--color-brand-500);
    font-weight: 600;
  }
  :where(.dark) .rt-toc-link[data-active="true"] {
    border-color: var(--color-brand-400);
  }
  details.rt-toc-mobile[open] .rt-toc-mobile-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  function bindToc() {
    const list = document.getElementById("toc-list");
    const listMobile = document.getElementById("toc-list-mobile");
    const root = document.querySelector<HTMLElement>("[data-toc-root]");
    const rootMobile = document.querySelector<HTMLElement>(
      "[data-toc-mobile-root]",
    );
    if (!list && !listMobile) return;

    const article = document.querySelector<HTMLElement>("article.prose-rt");
    if (!article) {
      if (list) list.innerHTML = "";
      if (listMobile) listMobile.innerHTML = "";
      if (root) root.style.display = "none";
      if (rootMobile) rootMobile.style.display = "none";
      return;
    }

    const slug = (s: string) =>
      s
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\s-]/g, "")
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-");

    const headings = Array.from(
      article.querySelectorAll<HTMLElement>("h2, h3"),
    );

    if (headings.length === 0) {
      if (list) list.innerHTML = "";
      if (listMobile) listMobile.innerHTML = "";
      if (root) root.style.display = "none";
      if (rootMobile) rootMobile.style.display = "none";
      return;
    }
    if (root) root.style.display = "";
    if (rootMobile) rootMobile.style.display = "";

    const html = headings
      .map((h) => {
        if (!h.id)
          h.id =
            slug(h.textContent || "") ||
            `h-${Math.random().toString(36).slice(2, 8)}`;
        const level = h.tagName === "H3" ? "3" : "2";
        // textContent strips the sr-only "Step N:" prefix already because we
        // intentionally use a child span; fall back to the visible text.
        const visibleText =
          (h.querySelector(":not(.sr-only)") as HTMLElement | null)
            ?.innerText ?? (h.textContent ?? "").trim();
        const safe = visibleText
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");
        return `<li><a href="#${h.id}" class="rt-toc-link" data-toc-link="${h.id}" data-toc-level="${level}">${safe}</a></li>`;
      })
      .join("");

    if (list) list.innerHTML = html;
    if (listMobile) listMobile.innerHTML = html;

    const links = new Map<string, HTMLAnchorElement[]>();
    document
      .querySelectorAll<HTMLAnchorElement>("[data-toc-link]")
      .forEach((a) => {
        const id = a.dataset.tocLink;
        if (!id) return;
        const arr = links.get(id) ?? [];
        arr.push(a);
        links.set(id, arr);
      });

    const setActive = (id: string | null) => {
      links.forEach((arr, key) => {
        for (const a of arr) {
          if (key === id) a.dataset.active = "true";
          else delete a.dataset.active;
        }
      });
    };

    // A manual selection (TOC click, hash deep-link, hashchange) wins over the
    // IntersectionObserver until either the user scrolls themselves or a short
    // grace period passes — long enough to cover smooth-scroll animation.
    let manualOverrideUntil = 0;
    const lockManual = (ms = 1500) => {
      manualOverrideUntil = Date.now() + ms;
    };
    const releaseManual = () => {
      manualOverrideUntil = 0;
    };

    // Tear down any listeners/observer registered by a previous bind so that
    // navigating between pages doesn't leak handlers onto window.
    const w = window as Window & { __tocCleanup?: () => void };
    w.__tocCleanup?.();

    const onTocClick = (e: Event) => {
      const target = e.target as HTMLElement | null;
      const a = target?.closest("[data-toc-link]") as
        | HTMLAnchorElement
        | null;
      if (!a) return;
      const id = a.dataset.tocLink;
      if (!id) return;
      setActive(id);
      lockManual();
      // Collapse the mobile drawer once the user picks a heading so the
      // scrolled-to target is actually visible.
      if (rootMobile && rootMobile instanceof HTMLDetailsElement) {
        rootMobile.open = false;
      }
    };
    list?.addEventListener("click", onTocClick);
    listMobile?.addEventListener("click", onTocClick);

    const onHashChange = () => {
      const id = decodeURIComponent((location.hash || "").replace(/^#/, ""));
      if (!id) return;
      if (links.has(id)) {
        setActive(id);
        lockManual();
      }
    };
    window.addEventListener("hashchange", onHashChange);

    // Reset the manual override the moment the user actually scrolls, so the
    // IntersectionObserver can take over once they've moved past the locked
    // section.
    const onUserScroll = () => releaseManual();
    const onUserKey = (e: KeyboardEvent) => {
      if (
        e.key === "PageDown" ||
        e.key === "PageUp" ||
        e.key === "ArrowDown" ||
        e.key === "ArrowUp" ||
        e.key === "Home" ||
        e.key === "End" ||
        e.key === " "
      ) {
        releaseManual();
      }
    };
    window.addEventListener("wheel", onUserScroll, { passive: true });
    window.addEventListener("touchmove", onUserScroll, { passive: true });
    window.addEventListener("keydown", onUserKey);

    const observer = new IntersectionObserver(
      () => {
        if (Date.now() < manualOverrideUntil) return;
        const offset = 120;
        let candidate = headings[0].id;
        for (const h of headings) {
          const top = h.getBoundingClientRect().top;
          if (top - offset <= 0) candidate = h.id;
          else break;
        }
        setActive(candidate);
      },
      {
        rootMargin: "-100px 0px -70% 0px",
        threshold: [0, 1],
      },
    );
    headings.forEach((h) => observer.observe(h));

    // If the page was opened with a hash, treat that as a manual selection so
    // the highlighted item matches the anchor the reader actually landed on.
    if (location.hash) {
      const id = decodeURIComponent(location.hash.replace(/^#/, ""));
      if (links.has(id)) {
        setActive(id);
        lockManual();
      } else {
        setActive(headings[0].id);
      }
    } else {
      setActive(headings[0].id);
    }

    w.__tocCleanup = () => {
      observer.disconnect();
      list?.removeEventListener("click", onTocClick);
      listMobile?.removeEventListener("click", onTocClick);
      window.removeEventListener("hashchange", onHashChange);
      window.removeEventListener("wheel", onUserScroll);
      window.removeEventListener("touchmove", onUserScroll);
      window.removeEventListener("keydown", onUserKey);
    };
  }

  bindToc();
  document.addEventListener("astro:page-load", bindToc);
</script>
